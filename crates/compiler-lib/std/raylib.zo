-! raylib bindings ‚Äî M1 surface (window only).
-!
-! Hand-written for M1. v2 will auto-generate this file from
-! the spec table in `crates/compiler/zo-binder` so adding new
-! raylib functions becomes one-line spec edits instead of
-! manual ffi declarations.

pack raylib;

-- ====================================================================
-- types ‚Äî mirror raylib's public structs.
-- ====================================================================

-! 2-component float vector.
pub struct Vector2 { x: f32, y: f32 }

-! 3-component float vector.
pub struct Vector3 { x: f32, y: f32, z: f32 }

-! 4-component float vector (also used for quaternions).
pub struct Vector4 { x: f32, y: f32, z: f32, w: f32 }

-- ====================================================================
-- window ‚Äî lifecycle.
-- ====================================================================

-! Initialise window and OpenGL context. `title` is a
-! C-string pointer ‚Äî wrap a literal with `c_str("‚Ä¶")`.
pub ffi init_window(width: int, height: int, title: int);

-! Check if KEY_ESCAPE pressed or close icon pressed.
pub ffi window_should_close() -> bool;

-! Close window and unload OpenGL context.
pub ffi close_window();

-! Set target frames per second (clamps loop to N FPS).
pub ffi set_target_fps(fps: int);

-! Setup canvas to start drawing this frame.
pub ffi begin_drawing();

-! End canvas drawing, swap buffers, poll events.
pub ffi end_drawing();

-! Clear background with `color`. The argument packs raylib's
-! `Color { r,g,b,a: u8 }` into the low 32 bits of an int ‚Äî
-! AArch64 AAPCS passes a 4-byte aggregate in the low half of
-! a single integer register, identical to a packed `u32`.
-! Layout (little-endian): byte 0 = r, byte 1 = g, byte 2 = b,
-! byte 3 = a. White opaque = `0xFFFFFFFF`. Black opaque =
-! `0xFF000000`.
pub ffi clear_background(color: int);

-! Draw `text` at (`x`, `y`) with `font_size` and `color`.
-! `text` is a C-string pointer (use `c_str("‚Ä¶")`); `color`
-! packs RGBA per `clear_background`'s convention.
pub ffi draw_text(text: int, x: int, y: int, font_size: int, color: int);

-! True the frame `key` was pressed. Key codes match
-! raylib's `KEY_*` constants ‚Äî e.g. `KEY_SPACE = 32`,
-! `KEY_ESCAPE = 256`.
pub ffi is_key_pressed(key: int) -> bool;

-! Time in seconds since the previous frame.
-! (raylib's `GetFrameTime` returns f32; widened to zo's
-! `float` (f64) at the FFI boundary so subsequent math
-! stays in double precision.)
pub ffi get_frame_time() -> float;

-! Draw a filled circle centred at (`x`, `y`) with `radius`
-! and `color`. `color` packs RGBA per `clear_background`'s
-! convention. Radius is narrowed from f64 to f32 at the FFI
-! boundary ‚Äî raylib's API takes f32.
pub ffi draw_circle(x: int, y: int, radius: float, color: int);

-! Draw a filled circle at `center` with `radius` and
-! `color`. `Vector2` passes by value ‚Äî its two f32 fields go
-! in `s0`/`s1` (HFA), then `radius` in `s2`, `color` in `w0`.
pub ffi draw_circle_v(center: Vector2, radius: float, color: int);

-! Current mouse position (in screen pixels). Returns by
-! value ‚Äî raylib writes the Vector2's f32 fields into
-! `s0`/`s1` (HFA), zo widens each to f64 and stores into a
-! local Vector2 struct.
pub ffi get_mouse_position() -> Vector2;

-! Current frame rate, measured by raylib's internal frame
-! timer. Returns 0 until raylib has accumulated enough
-! samples (typically a few frames into the loop).
pub ffi get_fps() -> int;
