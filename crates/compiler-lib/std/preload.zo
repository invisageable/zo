pack preload;

-! A value that may or may not be present.
pub enum Option<$T> {
  Some($T),
  None,
}

-! A value or an error.
pub enum Result<$T, $E> {
  Pass($T),
  Fail($E),
}

-! Runtime payload passed into `@input` / `@change` event
-! handler closures. `value` carries the input element's
-! current text. Future fields (`key`, `target`, ...) land
-! when a concrete program needs them.
pub struct Event {
  value: str,
}
