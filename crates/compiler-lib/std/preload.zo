pack preload;

-! A value that may or may not be present.
pub enum Option<$T> {
  Some($T),
  None,
}

-! A value or an error.
pub enum Result<$T, $E> {
  Ok($T),
  Err($E),
}

-- built-in abstracts.

-! Convert a value to its string representation.
pub abstract Show {
  fun show(self) -> str;
}

-! Equality comparison.
pub abstract Eq {
  fun eq(self, other: Self) -> bool;
}
