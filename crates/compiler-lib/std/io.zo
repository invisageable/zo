pack io;

-- show something to stdout without newline.
pub ext show(msg: str);

-- show something to stdout with ending line.
pub ext showln(msg: str);

-- show error message to stderr without newline.
pub ext eshow(msg: str);

-- show error message to stderr with ending line.
pub ext eshowln(msg: str);

-- read a line from stdin.
pub ext readln() -> str;

-- read all of stdin into a string.
pub ext read_all() -> str;

-- flush output buffers.
pub ext flush();
