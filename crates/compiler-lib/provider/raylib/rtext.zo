load core::c::*;

-! Draw text (using default font).
-!
-! @param text — The text content (pass as `CStr::new("…")`).
-! @param x — Horizontal pixel offset.
-! @param y — Vertical pixel offset.
-! @param font_size — The text size.
-! @param color — RGBA-packed color per `clear_background`.
%% link_name = "DrawText".
pub ffi draw_text(text: CStr, x: int, y: int, font_size: int, color: int);
