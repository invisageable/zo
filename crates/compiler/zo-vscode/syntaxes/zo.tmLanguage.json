{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "zo",
  "scopeName": "source.zo",
  "patterns": [
    {
      "include": "#line_comment"
    },
    {
      "include": "#line_doc_comment"
    },
    {
      "include": "#string_literal"
    },
    {
      "comment": "booleans",
      "name": "constant.language.boolean.zo",
      "match": "\\b(true|false)\\b"
    },
    {
      "comment": "integers literal (hex)",
      "name": "constant.numeric.integer.hexadecimal.zo",
      "match": "\\b(0x[a-fA-F0-9_]+)\\b"
    },
    {
      "comment": "integers literal (oct)",
      "name": "constant.numeric.integer.octal.zo",
      "match": "\\b(0o[0-7_]+)\\b"
    },
    {
      "comment": "integers literal (bin)",
      "name": "constant.numeric.integer.binary.zo",
      "match": "\\b(0b[01_]+)\\b"
    },
    {
      "comment": "floats literal",
      "name": "constant.numeric.float.zo",
      "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9_]+)?(f32|f64)?\\b"
    },
    {
      "comment": "integers literal (dec)",
      "name": "constant.numeric.integer.decimal.zo",
      "match": "\\b([0-9][0-9_]*)\\b"
    },
    {
      "comment": "single-quote string literal (character)",
      "name": "string.quoted.single.zo",
      "match": "b?'([^'\\\\]|\\\\(x[0-9A-Fa-f]{2}|[0-2][0-7]{0,2}|3[0-6][0-7]?|37[0-7]?|[4-7][0-7]?|.))'"
    },
    {
      "comment": "control flow keywords",
      "name": "keyword.control.zo",
      "match": "\\b(await|break|continue|each|else|for|if|is|loop|match|return|skip|spawn|stop|until|when|while)\\b"
    },
    {
      "comment": "keyword",
      "name": "keyword.other.zo",
      "match": "\\b(apply|as|async|and|css|ext|global|group|imu|load|macro|mock|mut|nursery|pack|pub|raw|state|test|unit|unsafe|val|wasm)\\b"
    },
    {
      "include": "#me"
    },
    {
      "comment": "attribute with args: %% foo(bar, ...)",
      "begin": "(%%)\\s*([A-Za-z][A-Za-z0-9_]*)(\\()",
      "end": "(\\))",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.attribute.zo"
        },
        "2": {
          "name": "entity.other.attribute-name.zo"
        },
        "3": {
          "name": "punctuation.definition.attribute.zo"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.attribute.zo"
        }
      },
      "patterns": [
        {
          "include": "$self"
        }
      ]
    },
    {
      "comment": "attribute: %% inline",
      "match": "(%%)\\s*([A-Za-z][A-Za-z0-9_]*)",
      "captures": {
        "1": {
          "name": "punctuation.definition.attribute.zo"
        },
        "2": {
          "name": "entity.other.attribute-name.zo"
        }
      }
    },
    {
      "comment": "directive",
      "match": "(#)([A-Za-z][A-Za-z0-9_]*)",
      "captures": {
        "1": {
          "name": "punctuation.definition.directive.zo"
        },
        "2": {
          "name": "keyword.control.directive.zo"
        }
      }
    },
    {
      "comment": "zsx closing tag",
      "match": "(<)(/)([A-Za-z][A-Za-z0-9_-]*)(>)",
      "captures": {
        "1": {
          "name": "punctuation.definition.tag.begin.zo"
        },
        "2": {
          "name": "punctuation.definition.tag.zo"
        },
        "3": {
          "name": "entity.name.tag.zo"
        },
        "4": {
          "name": "punctuation.definition.tag.end.zo"
        }
      }
    },
    {
      "comment": "zsx fragment <>...</>",
      "match": "(<)(/)?(>)",
      "captures": {
        "1": {
          "name": "punctuation.definition.tag.zo"
        },
        "2": {
          "name": "punctuation.definition.tag.zo"
        },
        "3": {
          "name": "punctuation.definition.tag.zo"
        }
      }
    },
    {
      "comment": "zsx opening tag",
      "begin": "(<)([A-Za-z][A-Za-z0-9_-]*)",
      "end": "(/?>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.zo"
        },
        "2": {
          "name": "entity.name.tag.zo"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.end.zo"
        }
      },
      "patterns": [
        {
          "include": "#zsx_attribute"
        }
      ]
    },
    {
      "comment": "thin arrow",
      "name": "keyword.operator.arrow.skinny.zo",
      "match": "->"
    },
    {
      "comment": "fat arrow",
      "name": "keyword.operator.arrow.fat.zo",
      "match": "=>"
    },
    {
      "comment": "miscellaneous op",
      "name": "keyword.operator.misc.zo",
      "match": "(::|:=|::=|\\?)"
    },
    {
      "comment": "comparison op",
      "name": "keyword.operator.comparison.zo",
      "match": "(&&|\\|\\||==|!=)"
    },
    {
      "comment": "assignment op",
      "name": "keyword.operator.assignment.zo",
      "match": "(\\+=|-=|/=|\\*=|%=|\\^=|&=|\\|=|<<=|>>=|=)"
    },
    {
      "comment": "arithmetic op",
      "name": "keyword.operator.arithmetic.zo",
      "match": "(!|\\+|(-(?!>))|(/(?!/))|\\*|%|\\^|&|\\||<<|>>)"
    },
    {
      "comment": "comparison op",
      "name": "keyword.operator.comparison.zo",
      "match": "(<=|>=|(<(?!<))|(>(?!>)))"
    },
    {
      "include": "#core_types"
    },
    {
      "comment": "generic type parameter $T",
      "match": "(\\$)([A-Z][A-Za-z0-9_]*)",
      "captures": {
        "1": {
          "name": "punctuation.definition.generic.zo"
        },
        "2": {
          "name": "entity.name.type.parameter.zo"
        }
      }
    },
    {
      "comment": "function call with modifier",
      "match": "\\b([A-Za-z][A-Za-z0-9_]*|_[A-Za-z0-9_]+)(@)([A-Za-z][A-Za-z0-9_]*)\\s*\\(",
      "captures": {
        "1": {
          "name": "entity.name.function.zo"
        },
        "2": {
          "name": "keyword.operator.modifier.zo"
        },
        "3": {
          "name": "entity.name.tag.modifier.zo"
        }
      }
    },
    {
      "comment": "function call",
      "match": "\\b([A-Za-z][A-Za-z0-9_]*|_[A-Za-z0-9_]+)\\s*\\(",
      "captures": {
        "1": {
          "name": "entity.name.function.zo"
        }
      }
    },
    {
      "comment": "function call with type parameters",
      "begin": "\\b([A-Za-z][A-Za-z0-9_]*|_[A-Za-z0-9_]+)\\s*(::)(?=\\s*<.*>\\s*\\()",
      "end": "\\(",
      "captures": {
        "1": {
          "name": "entity.name.function.zo"
        },
        "2": {
          "name": "keyword.operator.misc.zo"
        }
      },
      "patterns": []
    },
    {
      "comment": "closure expression: fn(...)",
      "match": "\\b(fn)\\s*(?=\\()",
      "captures": {
        "1": {
          "name": "keyword.other.fn.zo"
        }
      }
    },
    {
      "comment": "function type annotation: Fn(...)",
      "match": "\\b(Fn)\\s*(?=\\()",
      "captures": {
        "1": {
          "name": "support.type.primitive.zo"
        }
      }
    },
    {
      "comment": "function definition",
      "match": "\\b(fun)\\s+([A-Za-z][A-Za-z0-9_]*|_[A-Za-z0-9_]+)",
      "captures": {
        "1": {
          "name": "keyword.other.fun.zo"
        },
        "2": {
          "name": "entity.name.function.zo"
        }
      }
    },
    {
      "comment": "type declaration",
      "begin": "\\b(abstract|Fn|fn|enum|Me|struct|union)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "end": "[\\{\\(;]",
      "beginCaptures": {
        "1": {
          "name": "storage.type.zo"
        },
        "2": {
          "name": "entity.name.type.zo"
        }
      },
      "patterns": [
        {
          "include": "#line_comment"
        },
        {
          "include": "#line_doc_comment"
        },
        {
          "include": "#and"
        },
        {
          "include": "#core_types"
        }
      ]
    },
    {
      "comment": "type alias",
      "begin": "\\b(type)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "end": ";",
      "beginCaptures": {
        "1": {
          "name": "storage.type.zo"
        },
        "2": {
          "name": "entity.name.type.zo"
        }
      },
      "patterns": [
        {
          "include": "#line_comment"
        },
        {
          "include": "#line_doc_comment"
        },
        {
          "include": "#and"
        },
        {
          "include": "#core_types"
        }
      ]
    }
  ],
  "repository": {
    "line_comment": {
      "comment": "line comment",
      "name": "comment.line.double-slash.zo",
      "begin": "--",
      "end": "$"
    },
    "line_doc_comment": {
      "comment": "line doc comment",
      "name": "comment.line.documentation.zo",
      "begin": "-!",
      "end": "$"
    },
    "escaped_character": {
      "name": "constant.character.escape.zo",
      "match": "\\\\(x[0-9A-Fa-f]{2}|[0-2][0-7]{0,2}|3[0-6][0-7]?|37[0-7]?|[4-7][0-7]?|.)"
    },
    "string_literal": {
      "comment": "double-quote string literal",
      "name": "string.quoted.double.zo",
      "begin": "b?\"",
      "end": "\"",
      "patterns": [
        {
          "include": "#escaped_character"
        }
      ]
    },
    "me": {
      "comment": "me/self variable",
      "name": "variable.language.zo",
      "match": "\\b(me|Me|self|Self)\\b"
    },
    "and": {
      "comment": "and keyword",
      "name": "keyword.other.zo",
      "match": "\\b(and)\\b"
    },
    "zsx_attribute": {
      "patterns": [
        {
          "comment": "zsx event binding @event={expression}",
          "begin": "(@)([A-Za-z][A-Za-z0-9_]*)(=)(\\{)",
          "end": "(\\})",
          "beginCaptures": {
            "1": {
              "name": "keyword.operator.modifier.zo"
            },
            "2": {
              "name": "entity.other.attribute-name.zo"
            },
            "3": {
              "name": "keyword.operator.assignment.zo"
            },
            "4": {
              "name": "punctuation.section.embedded.begin.zo"
            }
          },
          "endCaptures": {
            "1": {
              "name": "punctuation.section.embedded.end.zo"
            }
          },
          "patterns": [
            {
              "include": "$self"
            }
          ]
        },
        {
          "comment": "zsx attribute with expression value",
          "begin": "\\b([A-Za-z][A-Za-z0-9_-]*)(=)(\\{)",
          "end": "(\\})",
          "beginCaptures": {
            "1": {
              "name": "entity.other.attribute-name.zo"
            },
            "2": {
              "name": "keyword.operator.assignment.zo"
            },
            "3": {
              "name": "punctuation.section.embedded.begin.zo"
            }
          },
          "endCaptures": {
            "1": {
              "name": "punctuation.section.embedded.end.zo"
            }
          },
          "patterns": [
            {
              "include": "$self"
            }
          ]
        },
        {
          "comment": "zsx attribute with string value",
          "match": "\\b([A-Za-z][A-Za-z0-9_-]*)(?=\\s*=)",
          "captures": {
            "1": {
              "name": "entity.other.attribute-name.zo"
            }
          }
        },
        {
          "include": "#string_literal"
        }
      ]
    },
    "core_types": {
      "comment": "built-in/core type",
      "name": "support.type.primitive.zo",
      "match": "\\b(bool|int|uint|s8|s16|s32|s64|u8|u16|u32|u64|float|f32|f64|char|str|bytes)\\b"
    }
  }
}
