-- How the "builtin styling" works. Is it scoped CSS? we should check the plan.

fun main() {
  -- here we define some html as plain text.
	imu strong: str = "here's some <strong>html!!!</strong>";
  -- here we go, another directive, `#html` render html into the component
  imu paragraph: </> ::= <p>{#html strong}</p>;

  #dom paragraph;
}
