-! # how to match enums: 031-match-enum.zo
-!
-! @cmd: `zo run 031-match-enum.zo`
-!
-! `match` on an enum dispatches by variant. Unit variants
-! match by name; tuple variants bind the payload.

enum Loot {
  Gold(int),
  Potion(int),
  Nothing,
}

fun main() {
  imu reward: Loot = Loot::Gold(50);

  match reward {
    Loot::Gold(n) => showln(n),
    Loot::Potion(n) => showln(n),
    Loot::Nothing => showln(0),
  }
}

-- EXPECTED OUTPUT:
-- 50
