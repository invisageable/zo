-- examples: event binding with @event syntax.

fun handle_click() {}
fun handle_focus() {}

fun main() {
  imu app: </> ::= <>
    <div>
      <h1>Event Demo</h1>
      <button @click={handle_click}>Click me</button>
      <input type="text" placeholder="Focus me" @focus={handle_focus} />
    </div>
  </>;

  #dom app;
}
