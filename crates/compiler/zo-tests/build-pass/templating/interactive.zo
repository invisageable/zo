-- examples: button + input widgets (static, no events yet).

fun main() {
  imu form: </> ::= <>
    <form>
      <h1>Sign Up</h1>
      <input type="text" placeholder="Username" />
      <input type="text" placeholder="Email" />
      <button>Submit</button>
      <button>Cancel</button>
    </form>
  </>;

  #dom form;
}
