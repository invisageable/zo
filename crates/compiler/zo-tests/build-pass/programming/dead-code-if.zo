-- tests-build-pass: early return from if (from rust-prehistory).
-- @cmd — cargo run --bin zo -- build crates/compiler/zo-tests/build-pass/programming/dead_code_if.zo -o crates/compiler/zo-tests/build-pass/programming/dead_code_if

fun f() -> int {
  if 1 == 1 {
    return 42;
  }

  return 0;
}

fun main() {
  check(f() == 42);
}
