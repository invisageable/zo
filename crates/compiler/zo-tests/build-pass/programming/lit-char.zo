-- tests-build-pass: char literals and equality.
-- @cmd — cargo run --bin zo -- build crates/compiler/zo-tests/build-pass/programming/char.zo -o crates/compiler/zo-tests/build-pass/programming/char

fun main() {
  imu c: char = 'x';
  imu d: char = 'x';

  check(c == 'x');
  check('x' == c);
  check(c == c);
  check(c == d);
  check(d == c);
  check (d == 'x');
  check('x' == d);
}
