-- tests-build-pass: closure with multiple parameters.
-- @cmd — cargo run --bin zo -- build crates/compiler/zo-tests/build-pass/programming/closure-multi-param.zo -o crates/compiler/zo-tests/build-pass/programming/closure-multi-param

fun main() {
  imu add := fn(x: int, y: int) -> int => x + y;

  check@eq(add(10, 20), 30);
}