-- tests-run-pass: else-if chains (from rust-prehistory).
-- @cmd — cargo run --bin zo -- build crates/compiler/zo-tests/build-pass/programming/else_if.zo -o crates/compiler/zo-tests/build-pass/programming/else_if

fun main() {
  if 1 == 2 {
    check(false);
  } else if 2 == 3 {
    check(false);
  } else if 3 == 4 {
    check(false);
  } else {
    check(true);
  }

  if 1 == 2 {
    check(false);
  } else if 2 == 2 {
    check(true);
  }
}
