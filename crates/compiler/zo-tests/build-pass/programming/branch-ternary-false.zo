-- tests-build-pass: ternary selects false arm.
-- @cmd — cargo run --bin zo -- build crates/compiler/zo-tests/build-pass/programming/branch-ternary-false.zo -o crates/compiler/zo-tests/build-pass/programming/branch-ternary-false

fun main() {
  imu x: int = when false ? 1 : 2;

  check@eq(x, 2);
}
