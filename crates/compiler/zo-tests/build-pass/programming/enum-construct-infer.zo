-- tests-build-pass: enum construction with inferred type.
-- @cmd — cargo run --bin zo -- build crates/compiler/zo-tests/build-pass/programming/enum-construct-infer.zo -o crates/compiler/zo-tests/build-pass/programming/enum-construct-infer

enum Color {
  Red,
  Green,
  Blue,
}

fun main() {
  imu c = Color::Red;
  imu g = Color::Green;
  imu b = Color::Blue;
}
