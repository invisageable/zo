-- tests-build-pass: generic apply block.
-- @cmd — cargo run --bin zo -- build crates/compiler/zo-tests/build-pass/programming/generic-apply.zo -o crates/compiler/zo-tests/build-pass/programming/generic-apply

struct Pair<$T> {
  first: $T,
  second: $T,
}

apply Pair<$T> {
  fun new(a: $T, b: $T) -> Self {
    Self { first: a, second: b }
  }
}

fun main() {}
