-- tests-build-pass: string concatenation with ++.
-- @cmd — cargo run --bin zo -- build crates/compiler/zo-tests/build-pass/programming/lit-str-concat.zo -o crates/compiler/zo-tests/build-pass/programming/lit-str-concat

fun main() {
  imu a: str = "hello";
  imu b: str = " world";
  imu s: str = a ++ b;

  showln(s);
  showln("zo" ++ "!");
  showln("a" ++ "b" ++ "c");
}
