-- tests-build-pass: generic identity with monomorphization.
-- @cmd — cargo run --bin zo -- build crates/compiler/zo-tests/build-pass/programming/generic-identity.zo -o crates/compiler/zo-tests/build-pass/programming/generic-identity

fun identity<$T>(x: $T) -> $T { x }

fun main() {
  imu a: int = identity(42);
  imu b: str = identity("hello");

  showln(a);
  showln(b);
}
