-- tests-build-pass: mutual recursion even/odd (from rust-prehistory).
-- @cmd — cargo run --bin zo -- build crates/compiler/zo-tests/build-pass/programming/mutual_recursion.zo -o crates/compiler/zo-tests/build-pass/programming/mutual_recursion

fun even(n: int) -> bool {
  if n == 0 {
    return true;
  } else {
    return odd(n - 1);
  }
}

fun odd(n: int) -> bool {
  if n == 0 {
    return false;
  } else {
    return even(n - 1);
  }
}

fun main() {
  check(even(42));
  check(odd(45));
}
