-- tests-build-pass: early return from conditional.
-- @cmd — cargo run --bin zo -- build crates/compiler/zo-tests/build-pass/programming/early-return.zo -o crates/compiler/zo-tests/build-pass/programming/early-return

fun f() -> int {
  if true {
    return 1;
  }

  return 0;
}

fun main() {
  imu result: int = f();

  check(result == 1);
}
