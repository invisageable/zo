-- tests-build-pass: closure inline syntax.
-- @cmd — cargo run --bin zo -- build crates/compiler/zo-tests/build-pass/programming/closure-inline.zo -o crates/compiler/zo-tests/build-pass/programming/closure-inline

fun main() {
  imu f: Fn(int) -> int = fn(x: int) -> int => x * x;

  check@eq(f(7), 49);
}