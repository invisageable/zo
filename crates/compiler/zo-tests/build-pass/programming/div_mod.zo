-- tests-run-pass: division and modulo (from rust-prehistory).
-- @cmd — cargo run --bin zo -- build crates/compiler/zo-tests/build-pass/programming/div_mod.zo -o crates/compiler/zo-tests/build-pass/programming/div_mod

fun main() {
  imu x: int = 15;
  imu y: int = 5;

  imu d1: int = x / 5;
  check(d1 == 3);
  imu d2: int = x / 4;
  check(d2 == 3);
  imu d3: int = x / 3;
  check(d3 == 5);
  imu d4: int = x / y;
  check(d4 == 3);
  imu d5: int = 15 / y;
  check(d5 == 3);

  imu m1: int = x % 5;
  check(m1 == 0);
  imu m2: int = x % 4;
  check(m2 == 3);
  imu m3: int = x % 3;
  check(m3 == 0);
}
