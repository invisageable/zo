-- tests-build-pass: generic struct construction + field access.
-- @cmd — cargo run --bin zo -- build crates/compiler/zo-tests/build-pass/programming/generic-struct.zo -o crates/compiler/zo-tests/build-pass/programming/generic-struct

struct Pair<$T> {
  first: $T,
  second: $T,
}

fun main() {
  imu p := Pair { first: 10, second: 20 };

  showln(p.first);
  showln(p.second);
}
