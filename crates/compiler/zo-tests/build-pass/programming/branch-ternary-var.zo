-- tests-build-pass: ternary with variable condition.
-- @cmd — cargo run --bin zo -- build crates/compiler/zo-tests/build-pass/programming/branch-ternary-var.zo -o crates/compiler/zo-tests/build-pass/programming/branch-ternary-var

fun main() {
  imu a: int = 10;
  imu b: int = 20;
  imu max: int = when a > b ? a : b;

  check@eq(max, 20);
}
