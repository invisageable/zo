-- tests-build-pass: bitwise operations (from rust-prehistory).
-- @cmd — cargo run --bin zo -- build crates/compiler/zo-tests/build-pass/programming/bitwise.zo -o crates/compiler/zo-tests/build-pass/programming/bitwise

fun main() {
  mut a: int = 1;
  mut b: int = 2;

  a ^= b;
  b ^= a;
  a = a ^ b;

  showln(a);
  showln(b);

  check(0xf0 | 0xf == 0xff);
  check(0xf << 4 == 0xf0);
  check(0xf0 >> 4 == 0xf);
  check(-16 >> 2 == -4);
  check(0b1010_1010 | 0b0101_0101 == 0xff);
}
