-- tests-build-pass: tuple field access.
-- @cmd — cargo run --bin zo -- build crates/compiler/zo-tests/build-pass/programming/tuple-index.zo -o crates/compiler/zo-tests/build-pass/programming/tuple-index

fun main() {
  imu t := (10, 20);

  check@eq(t.0, 10);
  check@eq(t.1, 20);
  check@eq(t.0 + t.1, 30);
}
