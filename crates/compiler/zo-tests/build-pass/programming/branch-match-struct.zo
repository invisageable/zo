pub struct Rect {
  x: float,
  y: float,
  w: int,
  h: int,
}

fun main() {
  imu rect: Rect = Rect { x: 0.0, y: 14.0, w: 1080, h: 640 };

  match rect {
    Rect { x: 0.0, y, .. } => {
      showln(x);
      check@eq(x, 0.0);
    },
    Rect { x, y: 14.0, .. } => {
      showln(y);
      check@eq(y, 14.0);
    },
    Rect { x, y, w, h } => {      
      showln("x: {x}, y: {y}, w: {w}, h: {h}");
    },
  }
}
