-- tests-build-pass: prime counting via trial division.
-- @cmd — zo build primes.zo

fun is_prime(n: int) -> bool {
  if n < 2 {
    return false;
  }

  if n == 2 {
    return true;
  }

  if n % 2 == 0 {
    return false;
  }

  mut i: int = 3;

  while i * i <= n {
    if n % i == 0 {
      return false;
    }

    i = i + 2;
  }

  return true;
}

fun count_primes(limit: int) -> int {
  mut count: int = 0;
  mut n: int = 2;

  while n <= limit {
    if is_prime(n) {
      count = count + 1;
    }

    n = n + 1;
  }

  return count;
}

fun main() {
  check(is_prime(2));
  check(is_prime(7));
  check(is_prime(13));
  check@eq(count_primes(100), 25);
}
