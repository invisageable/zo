-- tests-build-pass: generic enum construction.
-- @cmd — cargo run --bin zo -- build crates/compiler/zo-tests/build-pass/programming/generic-enum.zo -o crates/compiler/zo-tests/build-pass/programming/generic-enum

enum Option<$T> {
  Some($T),
  None,
}

fun main() {
  imu x: Option = Option::Some(42);
  imu y: Option = Option::None;
}
