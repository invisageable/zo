-- tests-build-pass: ternary with arithmetic in arms.
-- @cmd — cargo run --bin zo -- build crates/compiler/zo-tests/build-pass/programming/branch-ternary-arith.zo -o crates/compiler/zo-tests/build-pass/programming/branch-ternary-arith

fun main() {
  imu x: int = 5;
  imu y: int = when x > 3 ? x * 2 : x + 1;

  check@eq(y, 10);
}
