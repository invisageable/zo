-- tests-build-pass: generic function with multiple type params.
-- @cmd — cargo run --bin zo -- build crates/compiler/zo-tests/build-pass/programming/generic-multi.zo -o crates/compiler/zo-tests/build-pass/programming/generic-multi

fun first<$A, $B>(a: $A, b: $B) -> $A { a }
fun second<$A, $B>(a: $A, b: $B) -> $B { b }

fun main() {
  imu a: int = first(42, "hello");
  imu b: int = second("world", 99);

  showln(a);
  showln(b);
}
