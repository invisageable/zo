-- tests-build-pass: division and modulo (from rust-prehistory).
-- @cmd — zo build binop-div-mod.zo

fun main() {
  imu x: int = 15;
  imu y: int = 5;

  check(x / 5 == 3);
  check(x / 4 == 3);
  check(x / 3 == 5);
  check(x / y == 3);
  check(15 / y == 3);

  check(x % 5 == 0);
  check(x % 4 == 3);
  check(x % 3 == 0);
  check(x % y == 0);
  check(15 % y == 0);
}
