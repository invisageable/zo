load core::c::*;
load provider::raylib::*;

-- raylib — opens an 800×600 white window with the text
-- "hello, zo!" at the top-left, runs at 60 FPS.
-- @cmd — zo build window.zo && ./window
--
-- Requires `brew install raylib` (macOS). SPACE or close
-- exits.

fun main() {
  init_window(800, 600, c_str("zo + raylib"));
  set_target_fps(60);

  loop {
    if window_should_close() { break }
    if is_key_pressed(32) { break }; -- KEY_SPACE = 32

    begin_drawing();
      clear_background(0xFF000000);                     -- white
      draw_text(c_str("hello, zo!"), 12, 12, 32, 0xFFFFFFFF);  -- white
    end_drawing();
  }

  close_window();
}
