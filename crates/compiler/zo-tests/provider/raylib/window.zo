load core::c::*;
load provider::raylib;

-- raylib — opens an 800×600 white window with the text
-- "hello, zo!" at the top-left, runs at 60 FPS.
-- @cmd — zo build window.zo && ./window
--
-- Requires `brew install raylib` (macOS). SPACE or close
-- exits.

fun main() {
  raylib::init_window(800, 600, CStr::new("zo + raylib"));
  raylib::set_target_fps(60);

  loop {
    if raylib::window_should_close() { break }
    if raylib::is_key_pressed(32) { break } -- KEY_SPACE = 32

    raylib::begin_drawing();
      raylib::clear_background(0xFF000000);                     -- white
      raylib::draw_text(CStr::new("hello, zo!"), 12, 12, 32, 0xFFFFFFFF);  -- white
    raylib::end_drawing();
  }

  raylib::close_window();
}
