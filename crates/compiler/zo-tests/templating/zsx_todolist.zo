load core::zsx::*;

fun main() {
  mut todos: []str = [];
  mut input_val: str = "";
  imu view: </> ::= <>
    <input
      value={input_val}
      @input={fn(e) => input_val = e.value}
      @submit={fn(e) => {
        todos.push(e.value);

        input_val = "";
      }}
    />
    <button @click={fn() => {
      todos.push(input_val);

      input_val = "";
    }}>Add</button>
    <ul>{todos.map(fn(t) => <li>{t}</li>)}</ul>
  </>;

  #render view;
}
