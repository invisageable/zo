-- tests-build-pass: remove duplicates from sorted array.
-- @cmd — zo run remove-duplicates.zo
--
-- given a sorted integer array, remove duplicates in-place so
-- each unique element appears only once. uses a read pointer i
-- and a write pointer unique. when a new distinct value is
-- found, write it at position unique.

fun main() {
  -- [1, 1, 2] => k=2, first 2 elements: [1, 2]
  mut a: []int = [1, 1, 2];
  mut unique: int = 1;
  mut number: int = a[0];
  mut i: int = 1;

  while i < 3 {
    if a[i] != number {
      number = a[i];
      a[unique] = number;
      unique += 1;
    }

    i += 1;
  }

  check@eq(unique, 2);
  check@eq(a[0], 1);
  check@eq(a[1], 2);

  -- [0, 0, 1, 1, 1, 2, 2, 3, 3, 4] => k=5
  mut b: []int = [0, 0, 1, 1, 1, 2, 2, 3, 3, 4];
  mut ub: int = 1;
  mut nb: int = b[0];
  mut j: int = 1;

  while j < 10 {
    if b[j] != nb {
      nb = b[j];
      b[ub] = nb;
      ub += 1;
    }

    j += 1;
  }

  check@eq(ub, 5);
  check@eq(b[0], 0);
  check@eq(b[1], 1);
  check@eq(b[2], 2);
  check@eq(b[3], 3);
  check@eq(b[4], 4);
}
