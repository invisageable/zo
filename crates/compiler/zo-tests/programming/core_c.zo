load core::c::*;

-- core::c — round-trip a zo str through `CStr::new` (strip
-- length prefix + validate, returns the bytes ptr) and a
-- runtime-staged `CBytes { ptr, len }` materialized via
-- `CBytes::to_str()`. Every C library that returns a
-- `(ptr, len)` pair (json::to_str, http body, file read)
-- lifts the bytes through `CBytes::to_str()` to get a real
-- zo str usable in interpolation, `showln`, slicing, and
-- storage.

fun main() {
  imu original: str = "hello, world";
  imu cs: CStr = CStr::new(original);
  check(cs.is_valid());

  -- Synthesize a CBytes that points at the same payload
  -- and length. The materialized copy is an independent
  -- heap str, not aliased into rodata.
  imu cb: CBytes = CBytes { ptr = cs.ptr, len = 12 as s64 };
  imu copy: str = cb.to_str();

  showln(original);
  showln(copy);

  -- A second round-trip on a different literal.
  imu zo: str = "zo";
  imu zo_cs: CStr = CStr::new(zo);
  imu zo_cb: CBytes = CBytes { ptr = zo_cs.ptr, len = 2 as s64 };
  imu zo_copy: str = zo_cb.to_str();

  showln(zo_copy);
  showln("DONE");
}

-- EXPECTED OUTPUT:
-- hello, world
-- hello, world
-- zo
-- DONE
