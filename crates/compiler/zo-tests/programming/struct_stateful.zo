struct Counter {
  x: int,
}

apply Counter {
  fun new() -> Self {
    Self { x = 0 }
  }

  fun decr(mut self) {
    self.x -= 1;
  }

  fun incr(mut self) {
    self.x += 1;
  }

  fun x(self) -> int {
    self.x
  }
}

fun main() {
  mut counter: Counter = Counter::new();

  check@eq(counter.x(), 0);

  showln(counter.x);

  counter.incr();
  counter.incr();

  showln(counter.x);

  check@eq(counter.x, 2);
  check@eq(counter.x(), 2);

  counter.decr();

  check@eq(counter.x(), 1);

  showln(counter.x());

  showln("DONE");
}

-- EXPECTED OUTPUT:
-- 0
-- 2
-- 1
-- DONE
