-- tests-build-pass: static sized arrays.
-- @cmd — zo run array-static.zo

fun main() {
  imu nums: [3]int = [10, 20, 30];

  check@eq(nums[0], 10);
  check@eq(nums[1], 20);
  check@eq(nums[2], 30);

  imu words: [2]str = ["foo", "bar"];

  for word := words {
    showln(word);
  }

  showln("DONE");
}

-- EXPECTED OUTPUT:
-- foo
-- bar
-- DONE
