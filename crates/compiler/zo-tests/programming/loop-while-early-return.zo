fun find_first_div(n: int) -> int {
  mut i: int = 2;

  while i < n {
    if n % i == 0 {
      return i;
    }

    i += 1;
  }

  return n;
}

fun main() {
  imu result: int = find_first_div(15);

  check@eq(result, 3);

  showln("find_first_div: {result}");

  showln("DONE");
}

-- EXPECTED OUTPUT:
-- find_first_div: 3
-- DONE
