-- tests-run-pass: generic function with inner BinOp.
--
-- Exercises the mono ty_id rewrite: the generic body has
-- `a + b` where both operands carry the generic's original
-- Ty::Infer ty_id. Without the instantiation pass's ty_id
-- substitution the cloned SIR would keep `Ty::Infer(..)` on
-- the BinOp, violating invariant 3 ("concrete ty_ids at
-- instantiation boundaries").

fun sum<$T>(a: $T, b: $T) -> $T { a + b }

fun main() {
  imu x: int = sum(10, 20);
  imu y: int = sum(1, 2);

  check@eq(x, 30);
  check@eq(y, 3);
}
