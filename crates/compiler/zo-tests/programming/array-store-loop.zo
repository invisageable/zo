-- tests-build-pass: array element assignment in a loop.
-- @cmd — zo run array-store-loop.zo

fun main() {
  mut squares: []int = [0, 0, 0, 0, 0];
  mut idx: int = 0;

  while idx < 5 {
    squares[idx] = idx * idx;
    idx = idx + 1;
  }

  check(squares[0] == 0);
  check(squares[1] == 1);
  check(squares[2] == 4);
  check(squares[3] == 9);
  check(squares[4] == 16);

  showln(squares);
  
  showln("DONE");
}

-- EXPECTED OUTPUT:
-- [0, 1, 4, 9, 16]
-- DONE
