-- tests-build-pass: as cast for primitive type conversions.
-- @cmd — zo build as_cast.zo

fun main() {
  -- int to char.
  imu c: char = 72 as char;
  showln(c);

  -- char to int.
  imu n: int = 'Z' as int;
  showln(n);

  -- int to float.
  imu f: float = 42 as float;
  showln(f);

  -- float to int (truncates).
  imu i: int = 3.14 as int;
  showln(i);

  -- bool to int.
  imu bi_true: int = true as int;
  imu bi_false: int = false as int;
  showln(bi_true);
  showln(bi_false);

  -- int to bool (zero is false, non-zero is true).
  imu b_zero: bool = 0 as bool;
  imu b_one: bool = 1 as bool;
  showln(b_zero);
  showln(b_one);

  -- bytes to str. bytes and str share the same
  -- `[len:u64][bytes]` layout — the cast is a free
  -- reinterpret so the buffer's content prints.
  imu buf: bytes = `hello`;
  imu s: str = buf as str;
  showln(s);

  showln("DONE");
}

-- EXPECTED OUTPUT:
-- H
-- 90
-- 42
-- 3
-- 1
-- 0
-- false
-- true
-- hello
-- DONE
