-- tests-run-pass: `Vec<T>::remove(idx) -> Option<T>` —
-- read the element at `idx`, shift the tail down by one
-- slot, decrement `len`. Out-of-bounds returns
-- `Option::None`.
-- @cmd — zo run vec-remove.zo

fun main() {
  mut v: Vec<int> = Vec::new();

  v.push(10);
  v.push(20);
  v.push(30);
  v.push(40);

  -- remove the middle element.
  match v.remove(1) {
    Option::Some(x) => showln(x),
    Option::None => showln("missing"),
  }

  check@eq(v.len(), 3);

  -- elements after the removed slot shifted down.
  match v.get(0) {
    Option::Some(x) => showln(x),
    Option::None => showln("missing"),
  }

  match v.get(1) {
    Option::Some(x) => showln(x),
    Option::None => showln("missing"),
  }

  match v.get(2) {
    Option::Some(x) => showln(x),
    Option::None => showln("missing"),
  }

  -- out-of-bounds.
  match v.remove(99) {
    Option::Some(x) => showln(x),
    Option::None => showln("missing"),
  }

  v.free();

  showln("DONE");
  flush();
}

-- EXPECTED OUTPUT:
-- 20
-- 10
-- 30
-- 40
-- missing
-- DONE
