-- tests-run-pass: a working TODO list — exercises structs,
-- `apply` methods (incl. `mut self`), `[]T` of user-defined
-- type, direct field write `self.field = !self.field`,
-- `arr[i].method()`, and string interpolation. Demonstrates
-- the language reaching a real-program threshold.
-- @cmd — zo run todo_list.zo

struct Todo {
  text: str,
  done: bool,
}

apply Todo {
  fun new(text: str) -> Self {
    Self { text: text, done: false }
  }

  fun toggle(mut self) {
    self.done = !self.done;
  }

  fun show(self) {
    imu text: str = self.text;

    if self.done {
      showln("[x] {text}");
    } else {
      showln("[ ] {text}");
    }
  }
}

fun main() {
  mut todos: []Todo = [];

  todos.push(Todo::new("buy milk"));
  todos.push(Todo::new("write zo"));
  todos.push(Todo::new("ship MVP"));

  -- mark second as done via the toggle method
  todos[1].toggle();

  for i := 0..todos.len {
    todos[i].show();
  }

  showln("---");

  imu n: int = todos.len;
  showln("total: {n}");
}

-- EXPECTED OUTPUT:
-- [ ] buy milk
-- [x] write zo
-- [ ] ship MVP
-- ---
-- total: 3
