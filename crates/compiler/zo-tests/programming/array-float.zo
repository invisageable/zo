-- tests-build-pass: float arrays.
-- @cmd — zo run array-float.zo

fun main() {
  imu pi: []float = [3.14, 2.71, 1.41];

  -- expected: 3.14
  showln(pi[0]);
  -- expected: 2.71
  showln(pi[1]);
  -- expected: 1.41
  showln(pi[2]);

  mut vals: []float = [1.0, 2.0];

  vals[0] = 9.99;

  -- expected: 9.99
  showln(vals[0]);
}
