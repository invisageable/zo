-- raylib M3 — open a window, draw text on a white
-- background at 60 FPS, exit on close-button or SPACE.
-- @cmd — zo build window.zo && ./window
--
-- Requires `brew install raylib` (macOS).
--
-- Manual visible test: an 800x600 white window appears with
-- the text "hello, zo!" rendered in black at the top-left.
-- Pressing SPACE or clicking the close button exits the
-- program with status 0.

fun main() {
  init_window(800, 600, "zo + raylib");
  set_target_fps(60);

  loop {
    when window_should_close() ? break : ();
    when is_key_pressed(32) ? break : ();   -- KEY_SPACE = 32

    begin_drawing();
    clear_background(0xFF000000);            -- white
    draw_text("hello, zo!", 12, 12, 32, 0xFFFFFFFF);  -- black
    end_drawing();
  }

  close_window();
}
