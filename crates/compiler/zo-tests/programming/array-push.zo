-- tests-build-pass: array push method.
-- @cmd — zo build array-push.zo

fun main() {
  mut arr: []int = [];

  arr.push(10);
  arr.push(20);
  arr.push(30);

  check@eq(arr.len, 3);
  check@eq(arr[0], 10);
  check@eq(arr[1], 20);
  check@eq(arr[2], 30);

  -- push in a loop.
  mut nums: []int = [];
  mut i: int = 0;

  while i < 5 {
    nums.push(i * i);
    i = i + 1;
  }

  check@eq(nums.len, 5);
  check@eq(nums[0], 0);
  check@eq(nums[1], 1);
  check@eq(nums[2], 4);
  check@eq(nums[3], 9);
  check@eq(nums[4], 16);

  showln(arr.len);
  showln(nums.len);
}
