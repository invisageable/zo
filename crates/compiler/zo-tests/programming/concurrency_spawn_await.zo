-- tests-run-pass: spawn a worker, await its int return, print it.
-- @cmd — zo build concurrency_spawn_await.zo

fun compute() -> int {
  42
}

fun main() {
  nursery {
    imu task: Task<int> = spawn compute();
    imu result: int = await task;

    showln("got {result}");
  }

  showln("DONE");
}

-- EXPECTED OUTPUT:
-- got 42
-- DONE
