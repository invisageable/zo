-- tests-build-pass: short-circuit `&&` / `||` — RHS side
-- effects are suppressed when LHS already determines the
-- result. `incr(y)` must NOT run when `x` is true in
-- `x || incr(y)`; its body would `check(false)` and abort.

fun incr(mut x: int) -> bool {
  x += 1;

  check(false);

  false
}

fun main() {
  imu x := 1 == 2 || 3 == 3;

  check(x);

  imu y: int = 10;

  showln(x || incr(y));

  check@eq(y, 10);

  if true && x {
    check(true);
  } else {
    check(false);
  }
}

-- EXPECTED OUTPUT:
-- true
