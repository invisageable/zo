-- tests-build-pass: str.lines() — LF split with CRLF tolerance.
-- @cmd — zo build str-lines.zo

fun main() {
  imu plain_src: str = "a\nb\nc";
  imu plain: []str = plain_src.lines();
  check@eq(plain.len, 3);
  check@eq(plain[0], "a");
  check@eq(plain[1], "b");
  check@eq(plain[2], "c");

  -- Trailing '\n' does NOT produce an empty final line.
  imu trail_src: str = "a\nb\n";
  imu trailing: []str = trail_src.lines();
  check@eq(trailing.len, 2);
  check@eq(trailing[0], "a");
  check@eq(trailing[1], "b");

  -- CRLF: the '\r' is stripped from each line end.
  imu crlf_src: str = "a\r\nb\r\nc";
  imu crlf: []str = crlf_src.lines();
  check@eq(crlf.len, 3);
  check@eq(crlf[0], "a");
  check@eq(crlf[1], "b");
  check@eq(crlf[2], "c");

  imu blank: str = "";
  imu empty: []str = blank.lines();
  check@eq(empty.len, 0);

  showln("ok");
}

-- EXPECTED OUTPUT:
-- ok
