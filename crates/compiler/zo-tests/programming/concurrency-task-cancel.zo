-- tests-build-pass: parent cancels a spawned task, reads back the flag.
-- @cmd — zo build concurrency-task-cancel.zo

fun worker() -> int {
  42
}

fun main() {
  supervise {
    imu task: Task<int> = spawn worker();

    task.cancel();

    imu is_cancelled: bool = task.cancelled();

    showln("cancelled: {is_cancelled}");
  }

  showln("DONE");
}

-- EXPECTED OUTPUT:
-- cancelled: true
-- DONE
