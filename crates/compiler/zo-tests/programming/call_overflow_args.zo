-- tests-build-pass: a direct call passes more than 8 args, so
-- the 9th spills to the stack and the leaf callee reads it from
-- its overflow slot.

fun add9(
  a: int,
  b: int,
  c: int,
  d: int,
  e: int,
  f: int,
  g: int,
  h: int,
  i: int,
) -> int {
  return a + b + c + d + e + f + g + h + i;
}

fun main() {
  imu sum: int = add9(1, 2, 3, 4, 5, 6, 7, 8, 9);

  showln(sum);
}

-- EXPECTED OUTPUT:
-- 45
