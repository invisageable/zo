-- tests-build-pass: exponentiation by squaring.
-- @cmd — zo build power.zo

fun power(base: int, exp: int) -> int {
  if exp == 0 {
    return 1;
  }

  mut result: int = 1;
  mut b: int = base;
  mut e: int = exp;

  while e > 0 {
    if e % 2 == 1 {
      result = result * b;
    }

    b = b * b;
    e = e / 2;
  }

  return result;
}

fun main() {
  check@eq(power(2, 0), 1);
  check@eq(power(2, 1), 2);
  check@eq(power(2, 10), 1024);
  check@eq(power(3, 5), 243);
  check@eq(power(5, 6), 15625);
}
