-- tests-run-pass: Vec<int> — push / pop / get / set /
-- len / is_empty round-trip + grow.
-- @cmd — zo build vec-basic.zo

fun main() {
  imu v: Vec<int> = Vec::new();

  -- empty.
  check@eq(v.len(), 0);
  check(v.is_empty());

  -- push.
  v.push(10);
  v.push(20);
  v.push(30);

  check@eq(v.len(), 3);
  check(!v.is_empty());

  -- get hits.
  match v.get(0) {
    Option::Some(x) => check@eq(x, 10),
    Option::None => check(false),
  }

  match v.get(2) {
    Option::Some(x) => check@eq(x, 30),
    Option::None => check(false),
  }

  -- get out-of-bounds returns None.
  match v.get(99) {
    Option::Some(_) => check(false),
    Option::None => check(true),
  }

  -- set in-bounds.
  check(v.set(1, 200));

  match v.get(1) {
    Option::Some(x) => check@eq(x, 200),
    Option::None => check(false),
  }

  -- set out-of-bounds returns false.
  check(!v.set(99, 0));

  -- pop returns last.
  match v.pop() {
    Option::Some(x) => check@eq(x, 30),
    Option::None => check(false),
  }

  check@eq(v.len(), 2);

  match v.pop() {
    Option::Some(x) => check@eq(x, 200),
    Option::None => check(false),
  }

  match v.pop() {
    Option::Some(x) => check@eq(x, 10),
    Option::None => check(false),
  }

  check@eq(v.len(), 0);
  check(v.is_empty());

  -- pop on empty returns None.
  match v.pop() {
    Option::Some(_) => check(false),
    Option::None => check(true),
  }

  -- grow past initial capacity (8). 20 pushes forces
  -- at least one grow.
  for i := 0..20 => v.push(i * 100);

  check@eq(v.len(), 20);

  match v.get(15) {
    Option::Some(x) => check@eq(x, 1500),
    Option::None => check(false),
  }

  v.free();

  showln("ok");
}

-- EXPECTED OUTPUT:
-- ok
