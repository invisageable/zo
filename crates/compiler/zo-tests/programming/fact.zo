-- tests-build-pass: factorial (from rust-prehistory).
-- @cmd — zo run fact.zo

fun f(x: int) -> int {
  if x == 1 {
    return 1;
  } else {
    imu y: int = x * f(x - 1);

    return y;
  }
}

fun main() {
  imu result: int = f(5);

  check(result == 120);

  showln("f(5) = {result}");
  showln("DONE");
}

-- EXPECTED OUTPUT:
-- f(5) = 120
-- DONE
