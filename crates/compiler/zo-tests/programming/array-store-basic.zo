-- tests-build-pass: basic array element assignment.
-- @cmd — zo run array-store-basic.zo

fun main() {
  mut arr: []int = [0, 0, 0];

  arr[0] = 10;
  arr[1] = 20;
  arr[2] = 30;

  check(arr[0] == 10);
  check(arr[1] == 20);
  check(arr[2] == 30);

  showln(arr[0]);
  showln(arr[1]);
  showln(arr[2]);

  showln("DONE");
}

-- EXPECTED OUTPUT:
-- 10
-- 20
-- 30
-- DONE
