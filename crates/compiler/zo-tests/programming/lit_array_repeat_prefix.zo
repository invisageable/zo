-- tests-run-pass: `[v1, v2, v3...]` — prefix elements, last spreads.
-- @cmd — zo run lit_array_repeat_prefix.zo

fun main() {
  imu xs: [5]int = [1, 2, 3...];

  check@eq(xs[0], 1);
  check@eq(xs[1], 2);
  check@eq(xs[2], 3);
  check@eq(xs[3], 3);
  check@eq(xs[4], 3);

  showln(xs);
  showln("DONE");
}

-- EXPECTED OUTPUT:
-- [1, 2, 3, 3, 3]
-- DONE
