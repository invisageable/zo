-- tests-run-pass: a struct literal with two (or more)
-- float-returning call initializers must store each call's
-- OWN result into its field. `f()`'s result comes back in
-- D0, then `g()`'s call clobbers D0; the register allocator
-- spills `f()`'s value, but the post-call reload used to put
-- it back into D0 — clobbering `g()`'s freshly-returned
-- result. Both fields then read the same value, so `s.b`
-- aliased `s.a`. The GP path already reloaded X0-origin
-- values into a fresh register; the FP path now matches.
--
-- The int control (`P { a = fi(), b = gi() }`) never
-- regressed and pins the GP path so the two stay aligned.
-- @cmd — zo run struct_multi_float_call_fields.zo

struct S {
  a: float,
  b: float,
}

fun f() -> float { 1.0 }
fun g() -> float { 2.0 }

struct P {
  a: int,
  b: int,
}

fun fi() -> int { 10 }
fun gi() -> int { 20 }

fun main() {
  imu s: S = S { a = f(), b = g() };

  check@eq(s.a, 1.0);
  check@eq(s.b, 2.0);

  imu t: P = P { a = fi(), b = gi() };

  check@eq(t.a, 10);
  check@eq(t.b, 20);

  showln(s.a as int);
  showln(s.b as int);
  showln(t.a);
  showln(t.b);
}

-- EXPECTED OUTPUT:
-- 1
-- 2
-- 10
-- 20
