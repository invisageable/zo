-- tests-run-pass: HashMap pure-zo bodies — `len`,
-- `is_empty`, `free`. These three methods route through
-- the non-marshaling raw FFIs (`__zo_map_len_raw`,
-- `__zo_map_free_raw`) and therefore exercise the
-- generic-apply-method monomorphization path end-to-end:
-- their bodies are real zo, no codegen replacement.
-- @cmd — zo build hashmap-len-isempty.zo

fun main() {
  imu m: HashMap<int, int> = HashMap::new();

  -- Fresh map: len 0, is_empty true.
  check@eq(m.len(), 0);
  check(m.is_empty());

  m.insert(1, 100);
  m.insert(2, 200);

  check@eq(m.len(), 2);
  check(!m.is_empty());

  -- Remove drains is_empty back to true.
  match m.remove(1) {
    Option::Some(v) => check@eq(v, 100),
    Option::None => check(false),
  }
  check@eq(m.len(), 1);
  check(!m.is_empty());

  match m.remove(2) {
    Option::Some(v) => check@eq(v, 200),
    Option::None => check(false),
  }
  check@eq(m.len(), 0);
  check(m.is_empty());

  m.free();

  showln("ok");
}

-- EXPECTED OUTPUT:
-- ok
