-- tests-build-pass: ? operator for error propagation.
-- @cmd — zo build try_operator.zo

fun might_fail(x: int) -> Result<int, int> {
  if x < 0 {
    return Result::Fail(99);
  }

  return Result::Pass(x * 2);
}

fun compute(x: int) -> Result<int, int> {
  imu doubled: int = might_fail(x)?;

  return Result::Pass(doubled + 1);
}

fun main() {
  imu ok: Result<int, int> = compute(5);
  imu err: Result<int, int> = compute(-1);

  match ok {
    Result::Pass(v) => showln(v),
    Result::Fail(e) => showln(e),
  }

  match err {
    Result::Pass(v) => showln(v),
    Result::Fail(e) => showln(e),
  }
}

-- EXPECTED OUTPUT:
-- 11
-- 99
