-- tests-build-pass: arithmetic.
-- @cmd — zo run arithmetic.zo

fun main() {
  check(5.5 < 6.0);
  check(5.5 <= 6.0);
  check(6.0 > 5.5);
  check(6.0 >= 5.5);
  check(1 + 1 == 2);
  check(1 + 1 <= 2);
  check(1 + 1 >= 2);
  check(77 % 3 == 2);
  check(5 * 4 == 20);
  check(2 << 4 + 7 == 4096);
  check((2 << 4) + 7 == 39);
}
