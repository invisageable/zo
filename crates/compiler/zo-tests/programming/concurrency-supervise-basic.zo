-- tests-build-pass: `supervise { }` scopes green children the
-- same way `nursery { }` does — scope exit joins every child.
-- What distinguishes `supervise` from `nursery` is panic
-- cascading (a sibling panic propagates past the scope
-- instead of stopping here); this test validates the
-- happy-path drain semantics.
-- @cmd — zo build concurrency-supervise-basic.zo

fun worker_a() {
  showln("worker a");
}

fun worker_b() {
  showln("worker b");
}

fun main() {
  supervise {
    spawn worker_a();
    spawn worker_b();
  }

  showln("supervise done");
}

-- EXPECTED OUTPUT:
-- worker a
-- worker b
-- supervise done
