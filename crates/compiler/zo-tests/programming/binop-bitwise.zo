-- tests-build-pass: bitwise operations (from rust-prehistory).
-- @cmd — zo build binop-bitwise.zo

fun main() {
  mut a: int = 1;
  mut b: int = 2;

  a ^= b;
  b ^= a;
  a = a ^ b;

  showln(a);
  showln(b);

  check(0xf0 | 0xf == 0xff);
  check((0xf << 4) == 0xf0);
  check((0xf0 >> 4) == 0xf);
  check((0b1010_1010 | 0b0101_0101) == 0xff);
}
