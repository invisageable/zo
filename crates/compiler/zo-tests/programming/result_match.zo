-- tests-build-pass: generic Result match with all field types.
-- @cmd — zo build result_match.zo

fun ok_str() -> Result<str, int> {
  return Result::Pass("success");
}

fun err_str() -> Result<int, str> {
  return Result::Fail("failure");
}

fun ok_int() -> Result<int, int> {
  return Result::Pass(42);
}

fun err_int() -> Result<int, int> {
  return Result::Fail(99);
}

fun main() {
  -- Result<str, int>: Ok path.
  mut a := ok_str();

  match a {
    Result::Pass(s) => showln(s),
    Result::Fail(e) => showln(e),
  }

  -- Result<int, str>: Err path.
  mut b := err_str();

  match b {
    Result::Pass(n) => showln(n),
    Result::Fail(e) => showln(e),
  }

  -- Result<int, int>: Ok path.
  mut c := ok_int();

  match c {
    Result::Pass(n) => showln(n),
    Result::Fail(e) => showln(e),
  }

  -- Result<int, int>: Err path.
  mut d := err_int();

  match d {
    Result::Pass(n) => showln(n),
    Result::Fail(e) => showln(e),
  }
}

-- EXPECTED OUTPUT:
-- success
-- failure
-- 42
-- 99
