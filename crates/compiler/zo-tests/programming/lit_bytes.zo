-- tests-run-pass: `bytes` is a multi-byte buffer (the
-- plural is the contract — same layout as Rust's b"...").
-- The literal `\`...\`` captures the full source bytes
-- between the backticks; equality is buffer-vs-buffer.

fun main() {
  -- ASCII string literal — 5 bytes.
  imu hello: bytes = `hello`;
  check@eq(hello, `hello`);
  showln(hello);

  -- Multi-byte UTF-8 sequence stays intact.
  imu yen: bytes = `¥`;
  check@eq(yen, `¥`);
  showln(yen);

  -- Three-byte UTF-8 sequence (Π = 0xCE 0xA0).
  imu pi: bytes = `Π`;
  check@eq(pi, `Π`);
  showln(pi);

  -- Mixed ASCII + multi-byte.
  imu mix: bytes = `hello, ¥orld`;
  check@eq(mix, `hello, ¥orld`);
  showln(mix);

  showln("DONE");
}

-- EXPECTED OUTPUT:
-- hello
-- ¥
-- Π
-- hello, ¥orld
-- DONE
