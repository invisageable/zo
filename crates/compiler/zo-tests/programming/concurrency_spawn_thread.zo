-- tests-build-pass: spawn thread runs on a dedicated OS thread.
-- @cmd — zo build concurrency_spawn_thread.zo

fun heavy_worker() {
  showln("started task");

  imu total: int = 1_000_000;
  mut sum: int = 0;

  for x := 0..total => sum += x;

  showln("crunching {sum} items");
  showln("finished task");
}

fun main() {
  nursery {
    imu task: Task<unit> = spawn thread heavy_worker();

    await task;
  }

  showln("DONE");
}

-- EXPECTED OUTPUT:
-- started task
-- crunching 499999500000 items
-- finished task
-- DONE
