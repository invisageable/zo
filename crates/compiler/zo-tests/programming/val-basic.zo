-- tests-build-pass: val compile-time constants.
-- @cmd — zo build val-basic.zo

val ANSWER: int = 42;
val COUNT: int = 10;

fun main() {
  val LOCAL: int = 99;

  showln(ANSWER);
  showln(COUNT);
  showln(LOCAL);
  showln(ANSWER + COUNT);

  check@eq(ANSWER, 42);
  check@eq(COUNT, 10);
  check@eq(LOCAL, 99);
  check@eq(ANSWER + COUNT, 52);
}
