-- tests-build-pass: str.trim() — strip ASCII whitespace from both ends.
-- @cmd — zo build str_trim.zo

fun main() {
  check@eq("  hello  ".trim(), "hello");
  check@eq("\thello\n".trim(), "hello");
  check@eq("\r\nabc\r\n".trim(), "abc");

  -- Internal whitespace preserved.
  check@eq("  hello world  ".trim(), "hello world");

  -- Idempotent on already-trimmed input.
  check@eq("hello".trim(), "hello");

  -- All-whitespace input becomes empty.
  check@eq("   \t\n  ".trim(), "");

  check@eq("".trim(), "");

  showln("DONE");
}

-- EXPECTED OUTPUT:
-- DONE
