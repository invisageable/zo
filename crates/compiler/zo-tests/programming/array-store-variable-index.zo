-- tests-build-pass: array store with variable and expression indices.
-- @cmd — zo run array-store-variable-index.zo

fun main() {
  mut arr: []int = [0, 0, 0, 0];
  mut idx: int = 2;

  arr[idx] = 42;
  check(arr[idx] == 42);
  showln(arr);

  -- overwrite.
  arr[idx] = 99;
  check(arr[idx] == 99);
  showln(arr);

  showln("DONE");
}

-- EXPECTED OUTPUT:
-- [0, 0, 42, 0]
-- [0, 0, 99, 0]
-- DONE
