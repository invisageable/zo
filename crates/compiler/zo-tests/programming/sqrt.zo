-- tests-build-pass: integer square root via binary search.
-- @cmd — zo build sqrt.zo

fun isqrt(n: int) -> int {
  mut l: int = 0;
  mut h: int = n;

  while l <= h {
    imu m: int = (l + h) / 2;
    
    if m * m <= n {
      l = m + 1;
    } else {
      h = m - 1;
    }
  }

  return h;
}

fun main() {
  check@eq(isqrt(0), 0);
  check@eq(isqrt(1), 1);
  check@eq(isqrt(4), 2);
  check@eq(isqrt(9), 3);
  check@eq(isqrt(16), 4);
  check@eq(isqrt(100), 10);
  check@eq(isqrt(144), 12);

  showln(isqrt(144)); -- prints `12`
}
