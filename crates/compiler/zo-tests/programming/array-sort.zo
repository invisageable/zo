-- tests-run-pass: `[]int.sort()` — in-place ascending
-- sort via the runtime. Phase D regression.
-- @cmd — zo build array-sort.zo

fun main() {
  -- shuffled, 7 elements (the largest size that
  -- currently produces a well-formed Mach-O binary; an
  -- unrelated layout bug makes the writer emit a
  -- dyld-rejected file when the array crosses 8+
  -- elements at this specific code shape — tracked
  -- separately).
  mut shuffled: []int = [3, 1, 4, 1, 5, 9, 2];
  
  shuffled.sort();
  
  check@eq(shuffled[0], 1);
  check@eq(shuffled[1], 1);
  check@eq(shuffled[2], 2);
  check@eq(shuffled[3], 3);
  check@eq(shuffled[4], 4);
  check@eq(shuffled[5], 5);
  check@eq(shuffled[6], 9);

  showln("shuffled: {shuffled}")

  -- already sorted (idempotent).
  mut sorted: []int = [1, 2, 3, 4, 5];
  
  sorted.sort();
  
  check@eq(sorted[0], 1);
  check@eq(sorted[4], 5);

  showln("sorted (idempotent): {sorted}");

  -- reverse-sorted.
  mut reversed_sorted: []int = [5, 4, 3, 2, 1];
  
  reversed_sorted.sort();
  
  check@eq(reversed_sorted[0], 1);
  check@eq(reversed_sorted[4], 5);

  showln("reverse-sorted: {reversed_sorted}");

  -- with negatives.
  mut with_neg: []int = [3, -1, 0, -10, 5];
  
  with_neg.sort();
  
  check@eq(with_neg[0], -10);
  check@eq(with_neg[1], -1);
  check@eq(with_neg[2], 0);
  check@eq(with_neg[3], 3);
  check@eq(with_neg[4], 5);

  showln("with-negative: {with_neg}");

  -- single element.
  mut single_element: []int = [42];
  
  single_element.sort();
  
  check@eq(single_element[0], 42);

  showln("single-element: {single_element}");

  showln("DONE");
}

-- EXPECTED OUTPUT:
-- shuffled: [1, 1, 2, 3, 4, 5, 9]
-- sorted (idempotent): [1, 2, 3, 4, 5]
-- reverse-sorted: [1, 2, 3, 4, 5]
-- with-negative: [-10, -1, 0, 3, 5]
-- single-element: [42]
-- DONE
