-- tests-build-pass: bool arrays.
-- @cmd — zo run array_bool.zo

fun main() {
  imu flags: []bool = [true, false, true, false];

  check(flags[0]);
  check(!flags[1]);
  check(flags[2]);
  check(!flags[3]);

  showln(flags);
  showln("DONE");
}

-- EXPECTED OUTPUT:
-- [true, false, true, false]
-- DONE