-- tests-run-pass: HashMap<str, int>
-- @cmd — zo build hashmap-string-keys.zo

-- string-keyed lookups + insert / contains / remove.
--
-- regression: validates per-call-site `key_kind = 1` (Str) derivation from the
-- binding annotation, so the runtime hashes the str payload instead of the
-- pointer bytes.

fun main() {
  imu hashmap: HashMap<str, int> = HashMap::new();

  check@eq(hashmap.len(), 0);
  check(hashmap.is_empty());

  hashmap.insert("alice", 100);
  hashmap.insert("bob", 200);
  hashmap.insert("carol", 300);

  check@eq(hashmap.len(), 3);

  showln(hashmap);

  -- str-keyed hash means two separate "alice" pointers
  -- hash + compare equal — the runtime walks the str
  -- payload bytes, not the pointer.
  match hashmap.get("alice") {
    Option::Some(v) => check@eq(v, 100),
    Option::None => check(false),
  }

  match hashmap.get("bob") {
    Option::Some(v) => check@eq(v, 200),
    Option::None => check(false),
  }

  match hashmap.get("carol") {
    Option::Some(v) => check@eq(v, 300),
    Option::None => check(false),
  }

  match hashmap.get("missing") {
    Option::Some(_) => check(false),
    Option::None => check(true),
  }

  check(hashmap.contains_key("bob"));
  check(!hashmap.contains_key("zzz"));

  match hashmap.remove("bob") {
    Option::Some(v) => check@eq(v, 200),
    Option::None => check(false),
  }

  check(!hashmap.contains_key("bob"));
  check@eq(hashmap.len(), 2);

  showln(hashmap);
  hashmap.free();
  showln(hashmap);

  showln("DONE");
}

-- EXPECTED OUTPUT:
-- {carol: 300, bob: 200, alice: 100}
-- {carol: 300, alice: 100}
-- {}
-- DONE
