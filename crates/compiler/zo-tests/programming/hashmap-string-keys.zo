-- tests-run-pass: HashMap<str, int> — string-keyed
-- lookups + insert / contains / remove. Phase C
-- regression: validates per-call-site `key_kind = 1`
-- (Str) derivation from the binding annotation, so the
-- runtime hashes the str payload instead of the
-- pointer bytes.
-- @cmd — zo build hashmap-string-keys.zo

fun main() {
  imu m: HashMap<str, int> = HashMap::new();

  check@eq(m.len(), 0);
  check(m.is_empty());

  m.insert("alice", 100);
  m.insert("bob", 200);
  m.insert("carol", 300);

  check@eq(m.len(), 3);

  -- str-keyed hash means two separate "alice" pointers
  -- hash + compare equal — the runtime walks the str
  -- payload bytes, not the pointer.
  match m.get("alice") {
    Option::Some(v) => check@eq(v, 100),
    Option::None => check(false),
  }

  match m.get("bob") {
    Option::Some(v) => check@eq(v, 200),
    Option::None => check(false),
  }

  match m.get("carol") {
    Option::Some(v) => check@eq(v, 300),
    Option::None => check(false),
  }

  match m.get("missing") {
    Option::Some(_) => check(false),
    Option::None => check(true),
  }

  check(m.contains_key("bob"));
  check(!m.contains_key("zzz"));

  match m.remove("bob") {
    Option::Some(v) => check@eq(v, 200),
    Option::None => check(false),
  }

  check(!m.contains_key("bob"));
  check@eq(m.len(), 2);

  m.free();

  showln("ok");
}

-- EXPECTED OUTPUT:
-- ok
