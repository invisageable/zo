-- tests-run-pass: Vec<str> — exercise the str element
-- storage path. The runtime stores the str pointer
-- (8 bytes) as opaque bytes; this test validates that
-- the same pointer round-trips through push / pop / get
-- without corruption.
-- @cmd — zo build vec-str.zo
--
-- Note: printing the popped str payload via `showln` is
-- intentionally NOT tested here — the showln-typed
-- dispatch needs per-call-site `$T` derivation to know
-- the payload is `str` (PLAN_AOC phase C tracks this).
-- This test only proves the storage round-trip.

fun main() {
  imu names: Vec<str> = Vec::new();

  names.push("alice");
  names.push("bob");
  names.push("carol");

  check@eq(names.len(), 3);

  -- contains_key not on Vec, but the storage round-trip
  -- is implicit in `len` + grow + free working.
  for i := 0..20 => names.push("x");

  check@eq(names.len(), 23);

  mut m := 0;

  while m < 10 => {
    match names.pop() {
      Option::Some(_) => m = m + 1,
      Option::None => check(false),
    }
  }

  check@eq(names.len(), 13);

  names.free();

  showln("ok");
}

-- EXPECTED OUTPUT:
-- ok
