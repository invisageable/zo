-- tests-run-pass: AoC 2024 day 1 — similarity score.
-- @cmd — zo build aoc-2024-d01.zo
--
-- For each value `v` in the left column, multiply by the
-- count of `v` in the right column. Sum across the left
-- column.
--
-- Picks part 2 because part 1 needs sort over the full
-- input (1000 pairs) and zo's sort runtime currently
-- rejects 8+ element arrays — see PLAN_AOC's Phase D
-- limitation note. Part 2 only needs a HashMap counter.

fun main() {
  mut text: str = "";

  match read_file("aoc-2024-d01.input") {
    Result::Ok(t) => text = t,
    Result::Err(code) => showln(code),
  }

  imu lines: []str = text.lines();

  mut lhs: Vec<int> = Vec::new();
  mut rhs_counts: HashMap<int, int> = HashMap::new();

  mut i: int = 0;

  while i < lines.len {
    imu line: str = lines[i];

    if line.len > 0 {
      imu parts: []str = line.split("   ");

      if parts.len == 2 {
        mut p0 := parts[0].parse_int();
        match p0 {
          Option::Some(l) => lhs.push(l),
          Option::None => showln(false),
        }

        mut p1 := parts[1].parse_int();
        match p1 {
          Option::Some(r) => {
            mut rc := rhs_counts.get(r);
            match rc {
              Option::Some(prev) => rhs_counts.insert(r, prev + 1),
              Option::None => rhs_counts.insert(r, 1),
            }
          }
          Option::None => showln(false),
        }
      }
    }

    i = i + 1;
  }

  mut score: int = 0;
  mut j: int = 0;
  imu n: int = lhs.len();

  while j < n {
    match lhs.get(j) {
      Option::Some(v) => {
        match rhs_counts.get(v) {
          Option::Some(c) => {
            score = score + v * c;
          }
          Option::None => {}
        }
      }
      Option::None => {}
    }

    j = j + 1;
  }

  showln(score);

  lhs.free();
  rhs_counts.free();

  showln("DONE");
}

-- EXPECTED OUTPUT:
-- 31
-- DONE
