-- tests-build-pass: select picks the arm whose channel fired.
-- @cmd — zo build concurrency-select-pick.zo

fun producer_a(tx: Tx<int>) {
  tx.send(10);
}

fun producer_b(tx: Tx<int>) {
  tx.send(20);
}

fun main() {
  nursery {
    imu (tx1, rx1) := channel(1);
    imu (tx2, rx2) := channel(1);

    spawn producer_a(tx1);
    spawn producer_b(tx2);

    select {
      rx1 => fn(value: int) => showln("chan1: {value}"),
      rx2 => fn(value: int) => showln("chan2: {value}"),
    }
  }

  showln("DONE");
}

-- EXPECTED OUTPUT:
-- chan1: 10
-- DONE
