-- tests-build-pass: shuffle array by interleaving halves.
-- @cmd — zo run shuffle.zo

fun shuffle(nums: []int, n: int) -> []int {
  mut ans: []int = [];
  mut i: int = 0;
  mut j: int = 0;
  mut count: int = 0;

  while count < n * 2 {
    if count % 2 == 0 {
      ans.push(nums[i]);

      i = i + 1;
    } else {
      ans.push(nums[n + j]);

      j = j + 1;
    }

    count = count + 1;
  }

  return ans;
}

fun main() {
  imu nums: []int = [2, 5, 1, 3, 4, 7];
  imu result: []int = shuffle(nums, 3);

  check@eq(nums.len, 6);
  check@eq(result.len, 6);

  showln(result);
}
