-- tests-run-pass: rule 110 — tight form using `[N]T` fixed
-- arrays, `[v...]` repeat-array literals, `for i := 0..n`
-- with a variable bound, and `when ? :` ternary. The
-- verbose `rule-110.zo` lives next to this one for the
-- compile-time comparison.
-- @cmd — zo run rule-110-tight.zo

fun main() {
  imu width: int = 31;
  imu gens: int = 15;
  imu rule: [8]int = [0, 1, 1, 1, 0, 1, 1, 0];

  mut row:  [31]int = [0...];
  mut next: [31]int = [0...];
  row[width - 1] = 1;

  for g := 0..gens {
    for p := 0..width {
      if row[p] == 1 {
        show('#');
      } else {
        show('.');
      }
    }

    showln("");

    for k := 0..width {
      imu left: int = when k > 0 ? row[k - 1] : 0;
      imu right: int = when k < width - 1 ? row[k + 1] : 0;
      imu pattern: int = left * 4 + row[k] * 2 + right;

      next[k] = rule[pattern];
    }

    row = next;
  }
}

