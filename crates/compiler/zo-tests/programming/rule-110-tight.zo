-- tests-run-pass: rule 110 written with verified zo features
-- (fixed-size `[N]T`, for-range with variable bound, if-expr,
-- `=>` single-line form). The verbose `rule-110.zo` lives next
-- to this one for comparison.
-- @cmd — zo run rule-110-tight.zo

fun main() {
  imu width: int = 31;
  imu gens: int = 15;
  imu rule: [8]int = [0, 1, 1, 1, 0, 1, 1, 0];

  mut row: []int = [];
  for i := 0..width => row.push(0);
  row[width - 1] = 1;

  for g := 0..gens {
    for p := 0..width {
      if row[p] == 1 {
        show('#');
      } else {
        show('.');
      }
    }

    showln("");

    mut next: []int = [];
    for j := 0..width => next.push(0);

    for k := 0..width {
      imu left: int = when k > 0 ? row[k - 1] : 0;
      imu right: int = when k < width - 1 ? row[k + 1] : 0;
      imu pattern: int = left * 4 + row[k] * 2 + right;

      next[k] = rule[pattern];
    }

    row = next;
  }
}

