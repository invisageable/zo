-- tests-run-pass: base64 encode/decode round-trip.

load core::encoding::base64;

fun main() {
  check@eq(base64::encode(""), "");
  check@eq(base64::encode("zo"), "em8=");
  check@eq(base64::encode("Hello, World!"), "SGVsbG8sIFdvcmxkIQ==");

  check@eq(base64::decode(""), "");
  check@eq(base64::decode("em8="), "zo");
  check@eq(base64::decode("SGVsbG8sIFdvcmxkIQ=="), "Hello, World!");
  check@eq(base64::decode("not!base64!"), ""); -- Invalid input: empty string.

  showln("DONE");
}

-- EXPECTED OUTPUT:
-- DONE
