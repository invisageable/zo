-! # how to errors: 004-lit-char-unterminated.zo
-!
-! @cmd: `zo build 004-lit-char-unterminated.zo`
-!
-! Character literals use single quotes: 'a', 'z', '0'.
-!
-! A `char` is a single "atom" of data—a 32-bit Unicode scalar.
-! Just like strings, they must be closed. If you forget the
-! closing quote, zo catches it immediately on the same line.

fun main() {
  -- Mistake: Missing the closing single quote.
  imu c: char = 'a;
}

-! ## the diagnostic map.
-!
-! zo identifies the opening `'` and scans for the end. Because it
-! reaches the end of the line (or a semicolon) without finding a
-! matching `'`, it triggers a syntax error.
-!
-! ## try this.
-!
-!   1. Add the closing single quote: `'a'`.
-!   2. Try an escape: `'\n'` is a valid `char` (a single newline).
-!   3. Try `'ab'` — A `char` is exactly **one** character. Putting
-!      two characters inside single quotes will trigger a different
-!      error: "Character literal too long."

-- EXPECTED OUTPUT:
-- [E0005] Error: Unterminated character literal
--     ╭─[ 004-lit-char-unterminated.zo:13:17 ]
--     │
--  13 │   imu c: char = 'a;
--     │                 ─┬
--     │                  ╰── unterminated character
-- ────╯
