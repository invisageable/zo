struct Person {
  name: str,
  age: u8,
  position: Position,
}

struct Position {
  x: float,
  y: float,
}

fun main() {
  imu john: Person = Person {
    name: "john",
    age: 25,
    position: Position { x: 0.0, y: 8.0 },
  };

  imu jane: Person = Person {
    name: "jane",
    age: 23,
    position: Position { x: 9.0, y: -3.0 },
  };

  check@eq(john, jane);
}
