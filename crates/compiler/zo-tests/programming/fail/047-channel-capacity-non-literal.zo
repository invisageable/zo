-! # how to errors: 047-channel-capacity-non-literal.zo
-!
-! @cmd: `zo build 047-channel-capacity-non-literal.zo`
-!
-! Per `PLAN_CHANNELS.md` Phase 0 decision 5, `channel(N)`
-! currently requires `N` to be an integer literal. Variable
-! references and general expressions are post-MVP — they
-! need compile-time constant propagation to be useful
-! while staying safe.

fun main() {
  val BUF: int = 4;
  nursery {
    imu ch := channel(BUF);
  }
}
