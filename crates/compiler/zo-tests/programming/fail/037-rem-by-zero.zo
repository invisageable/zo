-! # how to errors: 037-rem-by-zero.zo
-!
-! @cmd: `zo build 037-rem-by-zero.zo`
-!
-! Remainder by zero is caught at compile time. The constant
-! folder evaluates `10 % 0` and reports the error.

fun main() {
  imu x: int = 10 % 0;
}

