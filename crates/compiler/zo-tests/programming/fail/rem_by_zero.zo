-! # how to errors: rem_by_zero.zo
-!
-! @cmd: `zo build rem_by_zero.zo`
-!
-! Remainder by zero is caught at compile time. The constant
-! folder evaluates `10 % 0` and reports the error.

fun main() {
  imu x: int = 10 % 0;
}

-- EXPECTED OUTPUT:
-- [E0501] Error • Remainder by zero
--    ╭─[ rem_by_zero.zo:9:19 ]
--    │
--  9 │   imu x: int = 10 % 0;
--    │                   ┬
--    │                   ╰── remainder by zero here
-- ───╯
