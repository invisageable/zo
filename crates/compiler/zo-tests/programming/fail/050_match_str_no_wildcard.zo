-! # how to errors: 050_match_str_no_wildcard.zo
-!
-! @cmd: `zo build 050_match_str_no_wildcard.zo`
-!
-! A `match` on `str` (or any other infinite type — `int`,
-! `float`, `char`, `bytes`) needs a `_` wildcard arm. Literal
-! arms can never enumerate every possible value.

fun main() {
  imu s: str = "hello";

  match s {
    "hello" => check(true),
    "world" => check(false),
  }
}

-- EXPECTED OUTPUT:
-- [E0333] Error: Non-exhaustive `match`
--     ╭─[ 050_match_str_no_wildcard.zo:12:11 ]
--     │
--  12 │   match s {
--     │           ┬
--     │           ╰── this `match` does not cover every possible value — add the missing arms or a `_` wildcard
-- ────╯
