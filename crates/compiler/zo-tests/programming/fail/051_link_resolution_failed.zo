-! # how to errors: 051_link_resolution_failed.zo
-!
-! @cmd: `zo build 051_link_resolution_failed.zo`
-!
-! A `#link { ... }` whose host entry resolves to
-! neither a system path on disk nor a vendored
-! prebuilt under `<exe-dir>/../lib/vendor/` must fail
-! at compile time — but ONLY when a `pub ffi` from the
-! pack is actually called. An unused broken `#link`
-! compiles silently; the diagnostic gates on usage.

pack missing_lib;

#link {
  macos: { system: "/definitely/does/not/exist.dylib",
           vendor: "libdefinitelymissing.dylib" },
  linux: { system: "/definitely/does/not/exist.so",
           vendor: "libdefinitelymissing.so" },
}

pub ffi some_fake_func() -> int;

fun main() {
  -- Calling the FFI is what triggers the diagnostic.
  -- A bare declaration with no call site stays silent.
  imu _r: int = some_fake_func();
}

-- EXPECTED OUTPUT:
-- [E0704] Error: Cannot resolve `#link` — neither system nor vendor library found
--     ╭─[ 051_link_resolution_failed.zo:15:20 ]
--     │
--  15 │   macos: { system: "/definitely/does/not/exist.dylib",
--     │                    ─────────────────┬────────────────
--     │                                     ╰────────────────── library not found at this path
--  16 │            vendor: "libdefinitelymissing.dylib" },
--     │                    ──────────────┬─────────────
--     │                                  ╰─────────────── vendor fallback also missing — expected under `<exe-dir>/../lib/vendor/`
-- ────╯
