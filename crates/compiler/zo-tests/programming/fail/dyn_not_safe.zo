-! # `any <Abstract>` rejected when the abstract is not
-! dyn-safe.
-!
-! @cmd: `zo build dyn_not_safe.zo`
-!
-! `Combine.merge(self, other: Self) -> Self` returns
-! `Self` AND takes a `Self`-typed argument past the
-! receiver — both break the vtable's uniform calling
-! convention. The abstract is dyn-unsafe; using it as
-! the type of a parameter (`any Combine`) raises
-! `E0349`.

abstract Combine {
  fun merge(self, other: Self) -> Self;
}

struct Tag {
  v: int,
}

apply Combine for Tag {
  fun merge(self, other: Tag) -> Tag {
    Tag { v = self.v + other.v }
  }
}

fun reduce(item: any Combine) -> int {
  0
}

fun main() {
  imu tag: Tag = Tag { v = 1 };

  showln(reduce(tag));
}

-- EXPECTED ERROR: E0349
