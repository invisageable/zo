-! # how to errors: 034_str_concat_int.zo
-!
-! @cmd: `zo build 034_str_concat_int.zo`
-!
-! Mirror of 033: `str ++ int` is also a type mismatch. The `++`
-! operator requires both sides to be `str`. No implicit conversion.

fun main() {
  imu s: str = "hello" ++ 42;
}

-- EXPECTED OUTPUT:
-- [E0304] Error • Type mismatch
--    ╭─[ 034_str_concat_int.zo:9:27 ]
--    │
--  9 │   imu s: str = "hello" ++ 42;
--    │                ───┬───    ─┬
--    │                   ╰─────────── conflicts with this type
--    │                            │
--    │                            ╰── incompatible type here
--    │
--    │ Note • The types of both operands must be compatible
-- ───╯
