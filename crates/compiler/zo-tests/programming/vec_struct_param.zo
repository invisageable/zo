-- tests-run-pass: a Vec<UserStruct> passed as a function
-- parameter. Guards the param-parser path where a generic
-- type argument is a user-defined type (Ident), not a
-- builtin type token.

struct Point {
  x: int,
  y: int,
}

fun sum_x(points: Vec<Point>) -> int {
  mut total: int = 0;

  for i := 0..points.len() {
    match points.get(i) {
      Option::Some(p) => { total += p.x; }
      Option::None => {}
    }
  }

  total
}

fun main() {
  mut points: Vec<Point> = Vec::new();

  points.push(Point { x = 10, y = 1 });
  points.push(Point { x = 20, y = 2 });
  points.push(Point { x = 30, y = 3 });

  showln(sum_x(points));

  points.free();
}

-- EXPECTED OUTPUT:
-- 60
