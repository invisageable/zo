-- @emit sir
--
-- Phase 8 of PLAN_CHANNELS. `spawn worker()` inside a
-- nursery must lower to `task.spawn`, NOT a regular
-- `call` — the executor redirects the call emission at
-- the matching RParen when `pending_spawn` is set.

fun worker() {}

fun main() {
  nursery {
    -- CHECK: task.spawn worker
    spawn worker();
  }
}
