-- @emit sir
--
-- Phase 8 of PLAN_CHANNELS. `channel()` is a compiler
-- intrinsic — it produces a `chan.new` SIR insn (plus a
-- wrapping tuple literal holding the tx/rx pair).
--
-- MVP uses single-binding access (`ch.0` / `ch.1`) because
-- parser-side tuple destructure patterns (`imu (tx, rx) :=
-- ...`) aren't yet supported — tracked as Phase 4b.

fun main() {
  nursery {
    -- CHECK: chan.new cap=0
    imu ch := channel();
  }
}
