-- tests-run-pass: sha1 + sha256 hex digests.

load core::hash;

fun main() {
  check@eq(hash::sha1(""), "da39a3ee5e6b4b0d3255bfef95601890afd80709");
  check@eq(hash::sha1("abc"), "a9993e364706816aba3e25717850c26c9cd0d89d");

  check@eq(
    hash::sha256(""),
    "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
  );
  check@eq(
    hash::sha256("abc"),
    "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad",
  );

  showln("DONE");
}

-- EXPECTED OUTPUT
-- DONE
