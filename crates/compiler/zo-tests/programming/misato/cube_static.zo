-- misato M1 — single static cube.
-- @cmd — zo build cube_static.zo && ./cube_static
--
-- Requires `brew install raylib` (macOS).
--
-- Manual visible test: 800x600 window opens; a single
-- white cube at the origin renders in 3D space, viewed
-- from a fixed camera at (3,3,3) looking at origin.
-- Background is light gray. SPACE or close exits.
--
-- Exercises the layer-3 stack:
--   misato.zo (zo wrappers)
--     ↓ ffi
--   libzo_misato.dylib (Rust runtime, ECS World)
--     ↓ extern C
--   libraylib.dylib (BeginMode3D / DrawCubeV / EndMode3D)

fun main() {
  init_window(800, 600, c_str("zo + misato — static cube"));
  set_target_fps(60);

  imu scene := Scene::new();
  imu camera := PerspectiveCamera::new(45.0, 1.33, 0.1, 1000.0);
  imu geom := BoxGeometry::new(1.0, 1.0, 1.0);
  imu mat := MeshStandardMaterial::new(0xFFFFFFFF);   -- white
  imu cube := Mesh::new(geom, mat);

  scene.add(cube);

  loop {
    if window_should_close() { break }
    if is_key_pressed(32)    { break }   -- SPACE.

    begin_drawing();
      clear_background(0xF5F5F5FF);   -- light gray
      scene.render(camera);
    end_drawing();
  }

  scene.close();
  close_window();
}
