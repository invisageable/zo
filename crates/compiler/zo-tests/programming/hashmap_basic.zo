-- tests-run-pass: HashMap<int, int> — insert / get /
-- contains_key / remove / len round-trip + grow.
-- @cmd — zo build map_basic.zo

fun main() {
  mut hashmap: HashMap<int, int> = HashMap::new();

  -- empty.
  check@eq(hashmap.len(), 0);

  -- insert + get.
  hashmap.insert(1, 100);
  hashmap.insert(2, 200);
  hashmap.insert(3, 300);

  check@eq(hashmap.len(), 3);

  showln(hashmap);

  match hashmap.get(1) {
    Option::Some(v) => check@eq(v, 100),
    Option::None => check(false),
  }

  match hashmap.get(2) {
    Option::Some(v) => check@eq(v, 200),
    Option::None => check(false),
  }

  match hashmap.get(3) {
    Option::Some(v) => check@eq(v, 300),
    Option::None => check(false),
  }

  -- miss returns None.
  match hashmap.get(99) {
    Option::Some(_) => check(false),
    Option::None => check(true),
  }

  -- contains_key.
  check(hashmap.contains_key(2));
  check(!hashmap.contains_key(42));

  -- remove returns the old value, decrements len.
  match hashmap.remove(2) {
    Option::Some(v) => check@eq(v, 200),
    Option::None => check(false),
  }
  check@eq(hashmap.len(), 2);
  check(!hashmap.contains_key(2));

  -- removing twice returns None the second time.
  match hashmap.remove(2) {
    Option::Some(_) => check(false),
    Option::None => check(true),
  }

  -- grow past initial capacity (16). 32 inserts forces
  -- at least one rehash.
  for i := 0..32 => hashmap.insert(i + 100, i + 1000);

  check@eq(hashmap.len(), 34);

  match hashmap.get(120) {
    Option::Some(v) => check@eq(v, 1020),
    Option::None => check(false),
  }

  showln("DONE");
}

-- EXPECTED OUTPUT:
-- {1: 100, 3: 300, 2: 200}
-- DONE
