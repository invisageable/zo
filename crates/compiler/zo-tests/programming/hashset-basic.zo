-- tests-run-pass: HashSet<int> — insert / contains /
-- remove / len / is_empty round-trip + grow.
-- @cmd — zo build hashset-basic.zo

fun main() {
  imu s: HashSet<int> = HashSet::new();

  -- empty.
  check@eq(s.len(), 0);
  check(s.is_empty());

  -- first insert returns true (was new).
  check(s.insert(10));
  check(s.insert(20));
  check(s.insert(30));

  check@eq(s.len(), 3);
  check(!s.is_empty());

  -- duplicate insert returns false (was present).
  check(!s.insert(10));
  check(!s.insert(20));
  check@eq(s.len(), 3);

  -- contains.
  check(s.contains(10));
  check(s.contains(20));
  check(s.contains(30));
  check(!s.contains(99));

  -- remove returns true on hit, false on miss.
  check(s.remove(20));
  check(!s.contains(20));
  check@eq(s.len(), 2);

  check(!s.remove(99));
  check@eq(s.len(), 2);

  -- removed key can be re-inserted as new.
  check(s.insert(20));
  check(s.contains(20));
  check@eq(s.len(), 3);

  -- grow past initial capacity (16). 32 inserts forces
  -- at least one rehash.
  for i := 0..32 => {
    check(s.insert(i + 100));
  }

  check@eq(s.len(), 35);
  check(s.contains(120));
  check(!s.contains(200));

  s.free();

  showln("ok");
}

-- EXPECTED OUTPUT:
-- ok
