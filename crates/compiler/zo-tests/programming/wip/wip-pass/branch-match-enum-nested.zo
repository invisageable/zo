enum Exit {
  Yes(int),
  No(int)
}

enum Process {
  Status(Exit),
}

fun main() {
  imu process: Process = Process::Status(Exit::Yes(0));

  match process {
    Process::Status(Exit::Yes(code)) => {
      check@eq(code, 0);
      showln(code);
    },
    Process::Status(Exit::No(code)) => {
      showln(code);
      check(false);
    },
  }
}
