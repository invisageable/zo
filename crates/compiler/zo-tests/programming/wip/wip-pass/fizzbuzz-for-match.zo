-- tests-run-pass: fizzbuzz-for-match.
-- @see https://en.wikipedia.org/wiki/Fizz_buzz.

fun fb(n: int) {
  mut x := 1;

  for x := 1..=n {
    match (x % 3, x % 5) {
      (0, 0) => showln("fizzbuzz"),
      (0, _) => showln("fizz"),
      (_, 0) => showln("buzz"),
      _ => showln("{x}"),
    }

    x += 1;
  }
}

fun main() {
  fb(100)
}
