struct Point {
  x: int,
  y: int,
}

apply Point {
  fun new(x: int, y: int) -> Self {
    Self { x, y }
  }
}

type Rect = (Point, Point);

fun f(rect: Rect, x: int, y: int, w: int, h: int) {
  check@eq(rect.0.x, x);
  check@eq(rect.0.y, y);
  check@eq(rect.1.x, x);
  check@eq(rect.1.y, y);
}

fun main() {
  imu r1: Rect = (Point::new(10, 20), Point::new(11, 22));

  check@eq(r1.0.x, 10);
  check@eq(r1.0.y, 20);
  check@eq(r1.0.x, 11);
  check@eq(r1.0.y, 22);

  imu r2: Rect = r1;
  imu x: int = r2.0.x;

  check@eq(r1.0.x, 10);

  f(r1, 10, 20, 11, 22);
  f(r2, 10, 20, 11, 22);
}
