-- tests-build-pass: `struct` default ctor.
-- @cmd — zo build struct_rect.zo

struct Rect {
  x: int = 10,
  y: int = 20,
  w: int = 100,
  h: int = 200,
}

fun f(r1: Rect, x: int, y: int, w: int, h: int) {
  check@eq(r1.x, x);
  check@eq(r1.y, y);
  check@eq(r1.w, w);
  check@eq(r1.h, h);
}

fun main() {
  imu r1: Rect = Rect::default();

  check@eq(r1.x, 10);
  check@eq(r1.y, 20);
  check@eq(r1.w, 100);
  check@eq(r1.h, 200);

  imu r2: Rect = r1;
  imu x: int = r2.x;

  check@eq(x, 10);

  f(r1, 10, 20, 100, 200);
  f(r2, 10, 20, 100, 200);

  showln("DONE");
}

-- EXPECTED OUTPUT:
-- DONE
