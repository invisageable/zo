-- tests-run-pass: arithmetic.

fun add(a: int, b: int) -> int {
  return a + b;
}

fun sub(a: int, b: int) -> int {
  return a - b;
}

fun mul(a: int, b: int) -> int {
  return a * b;
}

fun div(a: int, b: int) -> int {
  return a / b;
}

fun main() -> int {
  imu x: int = add(10, 20);
  imu y: int = sub(x, 5);
  imu z: int = mul(y, 2);
  imu result: int = div(z, 5);

  check@eq(x, 30);
  check@eq(y, 25);
  check@eq(z, 50);
  check@eq(result, 10);

  return result;
}
