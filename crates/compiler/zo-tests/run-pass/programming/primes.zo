// Prime number sieve
//
// Finds all prime numbers up to a limit using trial division.
// Demonstrates loops, conditionals, and early returns.

fn is_prime(n: i32) -> bool {
    if n < 2 {
        return false;
    }
    if n == 2 {
        return true;
    }
    if n % 2 == 0 {
        return false;
    }

    // Check odd divisors up to sqrt(n)
    let mut i = 3;
    while i * i <= n {
        if n % i == 0 {
            return false;
        }
        i = i + 2;
    }
    true
}

fn count_primes(limit: i32) -> i32 {
    let mut count = 0;
    let mut n = 2;
    while n <= limit {
        if is_prime(n) {
            count = count + 1;
        }
        n = n + 1;
    }
    count
}

fn main() -> i32 {
    // Print all primes up to 50
    let mut n = 2;
    while n <= 50 {
        if is_prime(n) {
            @dbg(n);
        }
        n = n + 1;
    }

    // Return the count of primes up to 100 (should be 25)
    count_primes(100)
}