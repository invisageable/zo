// Exponentiation by Squaring
//
// Computes x^n in O(log n) multiplications instead of O(n).
// A beautiful algorithm that uses the binary representation of n.

fn power(base: i32, exp: i32) -> i32 {
    if exp == 0 {
        return 1;
    }

    let mut result = 1;
    let mut b = base;
    let mut e = exp;

    while e > 0 {
        // If the current bit is set, multiply result by current power
        if e % 2 == 1 {
            result = result * b;
        }
        // Square the base and halve the exponent
        b = b * b;
        e = e / 2;
    }

    result
}

// Simple recursive version
fn power_recursive(base: i32, exp: i32) -> i32 {
    if exp == 0 {
        1
    } else {
        if exp % 2 == 0 {
            let half = power_recursive(base, exp / 2);
            half * half
        } else {
            base * power_recursive(base, exp - 1)
        }
    }
}

fn main() -> i32 {
    @dbg(power(2, 0));   // 1
    @dbg(power(2, 1));   // 2
    @dbg(power(2, 10));  // 1024
    @dbg(power(3, 5));   // 243
    @dbg(power(7, 4));   // 2401

    // Verify recursive version matches
    @dbg(power_recursive(2, 10));  // 1024

    // Return 5^6 = 15625
    power(5, 6)
}