---
import { textTransform } from "../../core/effects/text-transform";
import * as m from "../../paraglide/messages";
import Title from "../atoms/title.astro";
import Paragraph from "../atoms/paragraph.astro";
import Badge from "../indicators/badge.astro";

const description = "zo is built from the ground up using data-oriented design. Our niche is there to grow to build a new era of tools for the next-gen.";

const REPO = "invisageable/zo";
const headers: HeadersInit = import.meta.env.GITHUB_TOKEN
  ? { Authorization: `Bearer ${import.meta.env.GITHUB_TOKEN}` }
  : {};

// Pagination total via the `Link` header — avoids walking history.
function parseLastPage(link: string | null): number | null {
  const matched = link?.match(/[&?]page=(\d+)>;\s*rel="last"/);

  return matched ? Number(matched[1]) : null;
}

async function fetchStats() {
  try {
    const [repo, mergedRes, contribsRes, commitsRes] = await Promise.all([
      fetch(`https://api.github.com/repos/${REPO}`, { headers }).then((r) => r.json()),
      fetch(`https://api.github.com/search/issues?q=repo:${REPO}+is:pr+is:merged`, { headers }).then((r) => r.json()),
      fetch(`https://api.github.com/repos/${REPO}/contributors?per_page=1&anon=true`, { headers }),
      fetch(`https://api.github.com/repos/${REPO}/commits?per_page=1`, { headers }),
    ]);

    return {
      stars: repo.stargazers_count ?? 0,
      mergedPrs: mergedRes.total_count ?? 0,
      contributors: parseLastPage(contribsRes.headers.get("link")) ?? 1,
      commits: parseLastPage(commitsRes.headers.get("link")) ?? 1,
    };
  } catch {
    return { stars: 0, mergedPrs: 0, contributors: 0, commits: 0 };
  }
}

const rawStats = await fetchStats();

const stats = [
  { label: m.oss_stars(), value: rawStats.stars },
  { label: m.oss_merged_prs(), value: rawStats.mergedPrs },
  { label: m.oss_contributors(), value: rawStats.contributors },
  { label: m.oss_commits(), value: rawStats.commits },
];
---

<section data-section="oss" class="oss">
  <Title class="oss-title" as="h2"># oss</Title>
  <Paragraph content={textTransform(description)} />
  <ul class="oss-stats">
    {
      stats.map((stat) => <li class="oss-stats-item">
        <Badge value={stat.value} label={stat.label} />
      </li>)
    }
  </ul>
</section>

<script>
  import { renderer } from "../../core/renderer";
  import { observer } from "../../core/observer";
  import { watcher } from "../../core/watcher";
  import { Counter } from "../../core/effects/counter";

  watcher.add({
    selector: '[data-section="oss"] .badge-value',
    onMatch: (el) => {
      const target = Number(el.dataset.value ?? 0);
      const counter = new Counter(el, target);
      renderer.add(counter);
      observer.add(counter);
    },
  });

  renderer.render();
</script>

<style>
  .oss-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    margin: 24px 0 0;
    padding: 0;
    list-style: none;

    .oss-stats-item {
      padding: 2rem;
      display: flex;
      flex-direction: column;
      border: 1px solid color-mix(in oklab, var(--color-white-100) 10%, transparent);

      &:first-child {
        border-right: 0;
        border-bottom: 0;
      }

      &:last-child {
        border-top: 0;
        border-left: 0;
      }
    }
  }
</style>
