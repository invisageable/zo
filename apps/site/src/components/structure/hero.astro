---
import Title from "../atoms/title.astro";
import Header from "./header.astro";
import { textTransform } from "../../core/effects/text-transform";
import * as m from "../../paraglide/messages";
import { fetchLatestVersion } from "../../core/version";

const version = await fetchLatestVersion();
---

<section data-section="hero" class="hero">
  <Title as="h1" class="hero-title">zo</Title>
  <p class="hero-tagline f-aeonik" set:html={textTransform(m.hero_tagline())} />
  <span class="hero-compiler-latest-version">v{version}</span>
  <Header class="header--inline blur" />
</section>

<style>
  .hero {
    margin: 0 0 124px 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    animation: hero-enter 0.6s ease-out both;

    .hero-title {
      font-size: 24rem;
    }

    .hero-tagline {
      margin: 0;
      font-size: 30px;
      text-align: center;
    }

    .hero-compiler-latest-version {
      font-weight: 800;
    }
  }

  @keyframes hero-enter {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media only screen and (min-width: 768px) {
    .hero-tagline {
      max-width: 580px;
    }
  }
</style>
