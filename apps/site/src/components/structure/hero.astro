---
import Title from "../atoms/title.astro";
import Header from "./header.astro";
import { fetchLatestVersion } from "../../core/version";

const version = await fetchLatestVersion();
---

<section data-section="hero" class="hero">
  <Title as="h1" class="hero-title">zo</Title>
  <p class="hero-tagline f-aeonik">
    TURN YOUR <b class="green-100">THOUGHTS</b> iNTO <b class="green-100">TYPE-SAFE</b> SOFTWARE AND <b class="green-100">Ui</b> iNSTANTLY.
  </p>
  <span class="hero-compiler-latest-version">v{version}</span>
  <Header class="header--inline blur" />
</section>

<style>
  .hero {
    margin: 0 0 124px 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2rem;

    .hero-title {
      font-size: 24rem;
    }

    .hero-tagline {
      margin: 0;
      font-size: 30px;
      text-align: center;
    }

    .hero-compiler-latest-version {
      font-weight: 800;
    }
  }

  @media only screen and (min-width: 768px) {
    .hero-tagline {
      max-width: 580px;
    }
  }
</style>
