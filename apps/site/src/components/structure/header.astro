---
import { textTransform } from "../../core/effects/text-transform";
import * as m from "../../paraglide/messages";
import LocaleSwitcher from "../actions/locale-switcher.astro";
import Link from "../atoms/link.astro";
import IconMenu from "../../assets/icons/icon-menu.svg";

interface Props {
  class?: string;
  id?: string;
}

const { class: className, id } = Astro.props;
---

<header class:list={["header", className]} id={id}>
  <Link class="header-btn header-btn--home f-cirka" href="/" label="zo" />
  <Link class="header-btn header-btn--initiation" href="/initiation" label={textTransform(m.header_initiation())} />
  <Link class="header-btn header-btn--news" href="/news" label={textTransform(m.header_news())} />
  <LocaleSwitcher />
  <button type="button" class="header-burger" aria-label="menu" aria-expanded="false">
    <IconMenu width={14} height={14} />
  </button>
</header>

<script>
  import { renderer } from "../../core/renderer";
  import { watcher } from "../../core/watcher";
  import { StickyTopBar } from "../../core/effects/sticky-top-bar";

  // note(ivs): It's an illusion trick: any `.header--fixed` instance gets
  // paired with the in-flow `.header--inline` (cloned inside `.fold-center`).
  // We've to do this because CSS sticky rule doesn't work in the fold's blocks,
  // so the fixed copy fades in via class toggle once the in-flow one scrolls
  // past the viewport top.
  function init() {
    watcher.add({
      selector: ".header--fixed",
      onMatch: (fixed) => {
        renderer.add(
          new StickyTopBar(
            fixed,
            ".fold-center .fold-scroller .header--inline",
            document.querySelector<HTMLElement>(".screen"),
          ),
        );
      },
    });

    watcher.add({
      selector: ".header-burger",
      onMatch: (burger) => {
        burger.addEventListener("click", (event) => {
          event.stopPropagation();

          const navbar = document.querySelector(".navbar");
          if (!navbar) return;

          const opened = navbar.classList.toggle("navbar--open");
          burger.setAttribute("aria-expanded", String(opened));
        });
      },
    });
  }

  document.addEventListener("astro:page-load", init);

  // Document-level handlers attach once at module load — they don't need
  // re-binding on view transitions because document survives swaps.
  document.addEventListener("click", (event) => {
    const navbar = document.querySelector(".navbar");
    if (!navbar?.classList.contains("navbar--open")) return;
    if (navbar.contains(event.target as Node)) return;
    navbar.classList.remove("navbar--open");

    document
      .querySelectorAll<HTMLElement>(".header-burger")
      .forEach((b) => b.setAttribute("aria-expanded", "false"));
  });

  document.addEventListener("keydown", (event) => {
    if (event.key !== "Escape") return;

    document.querySelector(".navbar")?.classList.remove("navbar--open");
    document
      .querySelectorAll<HTMLElement>(".header-burger")
      .forEach((b) => b.setAttribute("aria-expanded", "false"));
  });
</script>

<style is:global>
  .header {
    display: flex;
    gap: 16px;
    justify-content: flex-end;
  }

  .header--fixed {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    height: var(--top-bar-height);
    box-sizing: border-box;
    align-items: center;
    padding: 0 calc(var(--sidebar-width) + 40px);
    background: rgba(0, 0, 0, 0.4);
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px);
    transition: opacity 0.24s ease, transform 0.24s ease;
  }

  .header--fixed.header--active {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .header--inline {
    z-index: 100;
  }

  .header--inline .header-btn--home,
  .header--inline .header-btn--news,
  .header--inline .locale-switcher-wrap {
    display: none;
  }
  
  .header--fixed a.header-btn {
    color: var(--color-white-100);
    opacity: 1;
    font-size: 14px;
  }

  .header--fixed a.header-btn--home {
    margin-right: auto;
    left: 4rem;
    top: 50%;
    line-height: 3rem;
    height: var(--top-bar-height);
    transform: translateY(-50%);
    position: absolute;
    font-size: 2rem;
  }

  .header--fixed a.header-btn--home,
  .header--fixed a.header-btn--home:hover {
    color: var(--color-white-100);
    text-decoration: none;
    outline: none;
  }

  .header-burger {
    display: none;
    align-items: center;
    justify-content: center;
    height: var(--top-bar-height);
    padding: 0 8px;
    background: transparent;
    border: 0;
    color: inherit;
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
  }

  @media (max-width: 768px) {
    /* Drop the desktop sidebar-padding so links + locale + burger
       have room to breathe on a phone. */
    .header--fixed {
      padding: 0 16px;
    }

    /* Burger only lives in the sticky/fixed header (the "header spy"),
       never in the inline header. */
    .header--fixed .header-burger {
      display: inline-flex;
    }
  }
</style>
