---
import type { Quote } from "../../core/quote";
import { textTransform } from "../../core/effects/text-transform";
import * as m from "../../paraglide/messages";
import Title from "../atoms/title.astro";
import Card from "./card.astro";
import iconUnified from "../../assets/icons/icon-deal.svg";
import iconFast from "../../assets/icons/icon-fast.svg";
import iconSafe from "../../assets/icons/icon-safe.svg";
import iconWorkstation from "../../assets/icons/icon-workstation.svg";
import Citation from "../atoms/citation.astro";

// Messages stored as plain text; textTransform converts to the zo
// styled form (UPPERCASE with lowercase i, plus zo/zsx/codelord
// preserved) at render time so translators write natural prose.
const features = [
  {
    icon: iconUnified,
    title: textTransform(m.features_unified_title()),
    content: textTransform(m.features_unified_content()),
  },
  {
    icon: iconFast,
    title: textTransform(m.features_fast_title()),
    content: textTransform(m.features_fast_content()),
  },
  {
    icon: iconSafe,
    title: textTransform(m.features_safe_title()),
    content: textTransform(m.features_safe_content()),
  },
  {
    icon: iconWorkstation,
    title: textTransform(m.features_integrated_title()),
    content: textTransform(m.features_integrated_content()),
  },
];

const quote: Quote = {
  sentence: m.features_quote(),
  author: "Chandler Carruth",
};
---

<section data-section="features" class="features">
  <Title class="gondola-title" as="h2">{m.features_title()}</Title>
  <div class="features-list" data-features-list>
    {
      features.map((feature) => <Card
        icon={feature.icon}
        title={feature.title}
        content={feature.content}
        class="features-card"
      />)
    }
  </div>
  <Citation sentence={quote.sentence} author={quote.author} />
</section>

<style is:global>
    .features-list {
      border: none;
      display: grid;
      gap: 1rem;
      /* grid-template-columns: none;
       */
      grid-template-columns: repeat(1, 1fr);
      grid-auto-flow: row;
      grid-auto-columns: 100%;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }

    .features-list::-webkit-scrollbar {
      display: none;
    }

    .features-card {
      scroll-snap-align: center;
      
      .card-content {
        font-size: 1rem;
      }
    }


    .features-card {
      /* border-bottom: 0; */
      /* &:last-child {
        border-bottom: inherit;
        border-bottom-style: solid;
      } */
    }

    @media (min-width: 768px) {
      .features-list {
        margin: 24px 0 0 0;
        grid-template-columns: repeat(2, 1fr);
        grid-auto-flow: dense;
        gap: 0;

        .features-card {
          scroll-snap-align: center;

          .card-content {
            font-size: 1.25vw;
          }
        }
      }
    
      .features-card:first-child {
        border-right: 0;
        border-bottom: 0;
      }
    
      .features-card:last-child {
        border-top: 0;
        border-left: 0;
      }
  }
</style>
