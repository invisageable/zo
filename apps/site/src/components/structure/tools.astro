---
import { textTransform } from "../../core/effects/text-transform";
import Paragraph from "../atoms/paragraph.astro";
import Title from "../atoms/title.astro";
import Card from "./card.astro";

const description = "The zo <b class='green-100'>workstation</b>. Tools built alongside the language, <b class='green-100'>evolving</b> with it.";

const TOOLS = [
  {
    name: "codelord",
    description: "An editor designed to <b class='green-100'>disappear</b>. Code your thoughts <b class='green-100'>instantly</b>.",
    image: "https://github.com/invisageable/codelord/raw/main/apps/coder/codelord-notes/public/assets/codelord-motion-preview-welcome.gif",
    link: "https://github.com/invisageable/codelord",
  },
  {
    name: "fret",
    description: "Package manager. <b class='green-100'>Zero config</b>. Built for <b class='green-100'>speed</b>, like the rest of zo.",
    link: "https://github.com/invisageable/zo/blob/main/crates/packager/fret",
  },
  {
    name: "zo vscode",
    description: "VS Code extension. <b class='green-100'>Bridge</b> zo to your editor while codelord matures.",
    link: "https://github.com/invisageable/zo/tree/main/crates/compiler/zo-vscode",
  },
];
---

<!-- gallery to expose: codelord, fret, zo-vscode -->

<section data-section="tools" class="tools">
  <Title as="h2">## tools</Title>
  <Paragraph content={textTransform(description)} />
  <div class="tools-gallery">
    {
      TOOLS.map((tool) => <a target="_blank" href={tool.link}>
        <Card
          class="tools-gallery-item"
          title={tool.name}
          content={textTransform(tool.description)}
          image={tool.image}
        />
      </a>)
    }
  </div>  
</section>

<style>
  .tools {
    .tools-gallery {
      display: grid;
      grid-template-columns: repeat(1, minmax(0, 1fr));
      gap: 20px;
      align-items: stretch;

      :global(.tools-gallery-item) {
        padding: 1rem;

        :global(&.card .card-title) {
          margin: 12px 0 0 0;
          font-size: 4.25vw;
        }

        :global(&.card .card-content) {
          color: var(--color-white-100);
        }
      }
    }
  }

  @media only screen and (min-width: 768px) {
    .tools {
      .tools-gallery {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
  }
</style>
