---
import { Image } from "astro:assets";
import { textTransform } from "../../core/effects/text-transform";
import * as m from "../../paraglide/messages";
import Title from "../atoms/title.astro";
import Paragraph from "../atoms/paragraph.astro";
import logoEgui from "../../assets/logos/logo-egui.png";
import logoRaylib from "../../assets/logos/logo-raylib.png";
import logoWgpu from "../../assets/logos/logo-wgpu.png";
import logoWry from "../../assets/logos/logo-wry.svg";

const FOUNDATiONS_LOGOS = [
  { src: logoEgui, alt: "egui", href: "https://github.com/emilk/egui" },
  { src: logoWgpu, alt: "wgpu", href: "https://github.com/gfx-rs/wgpu" },
  { src: logoWry, alt: "wry", href: "https://github.com/tauri-apps/wry" },
  { src: logoRaylib, alt: "raylib", href: "https://github.com/raysan5/raylib" },
];
---

<section data-section="foundations" class="foundations">
  <Title as="h2">{m.foundations_title()}</Title>
  <Paragraph content={textTransform(m.foundations_description())} />
  <ul class="foundations-logos">
    {
      FOUNDATiONS_LOGOS.map((logo) => <li>
        <a class="link" href={logo.href} target="_blank" rel="noopener">
          <Image class="logo" src={logo.src} alt={logo.alt} />
        </a>
      </li>
    )}
  </ul>
</section>

<style>
  .foundations-logos {
    margin: 24px 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 32px;
    align-items: center;
    list-style: none;

    .link {
      opacity: 0.7;

      &:hover {
        opacity: 1;
      }
    }

    .logo {
      height: 64px;
      width: auto;
      transition: opacity 350ms ease-in-out;
    }
  }
</style>
