---
interface Props {
  as?: 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6';
  class?: string;
}

const { as: Tag = 'h1', class: className } = Astro.props;
---

<Tag class={className}>
  <slot />
</Tag>

<style>
  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    margin: 0;
    padding: 0;
    font-family: var(--font-cirka);
  }

  h1 {
    font-size: 4rem;
    line-height: 1.1;
  }
  
  h2 {
    padding: calc(1.7em *0.5) 0 calc(1.7em *0.5) 0;
    font-size: 2.5rem;
    line-height: 1.2;
  }
  
  h3 {
    font-size: 1.75rem;
    line-height: 1.3;
  }
</style>
