---
interface Neighbor {
  slug: string;
  subtitle: string | null;
}

interface Props {
  prev: Neighbor | null;
  next: Neighbor | null;
}

const { prev, next } = Astro.props;
---

<nav class="speech-nav">
  {prev
    ? <a class="speech-nav-prev" href={`/speeches/${prev.slug}`}>← {prev.subtitle ?? "prev"}</a>
    : <span class="speech-nav-prev speech-nav--disabled">← prev</span>}
  {next
    ? <a class="speech-nav-next" href={`/speeches/${next.slug}`}>{next.subtitle ?? "next"} →</a>
    : <span class="speech-nav-next speech-nav--disabled">next →</span>}
</nav>

<style>
  .speech-nav {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    margin: 24px 0;
    font-family: var(--font-iosevka);
    font-size: 0.9rem;
  }

  .speech-nav a {
    color: inherit;
    opacity: 0.6;
    text-decoration: none;
  }

  .speech-nav a:hover {
    text-decoration: underline;
  }

  .speech-nav--disabled {
    opacity: 0.3;
  }
</style>
