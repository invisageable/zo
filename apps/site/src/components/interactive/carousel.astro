---
interface Props {
  class?: string;
  ariaLabel?: string;
  typewriter?: boolean;
}

const {
  class: className,
  ariaLabel = "carousel",
  typewriter = false,
} = Astro.props;
---

<div
  class:list={["carousel", className]}
  aria-roledescription="carousel"
  aria-label={ariaLabel}
  data-typewriter={typewriter ? "true" : null}
>
  <div class="carousel-viewport">
    <div class="carousel-track">
      <slot />
    </div>
  </div>
  <div class="carousel-nav">
    <button type="button" class="carousel-prev" aria-label="previous slide">◀</button>
    <div class="carousel-dots" role="tablist"></div>
    <button type="button" class="carousel-next" aria-label="next slide">▶</button>
  </div>
</div>

<script>
  import { watcher } from "../../core/watcher";
  import { Typewriter } from "../../core/effects/typewriter";

  // Scope to `.fold-center` only — the source and the before/after fold
  // copies inherit dots via deep cloneNode and would double up if we ran
  // here too. Only the visible center clone needs working controls.
  watcher.add({
    selector: ".fold-center .carousel",
    onMatch: (root) => {
      // Stacked guards — `data-carousel-init` and the dots-already-populated
      // check both prevent re-entry. Marked only AFTER successful init so
      // an early-firing on a partial DOM doesn't lock out a later valid one.
      if (root.dataset.carouselInit === "1") return;

      const track = root.querySelector<HTMLElement>(".carousel-track");
      const dotsHost = root.querySelector<HTMLElement>(".carousel-dots");
      const prev = root.querySelector<HTMLButtonElement>(".carousel-prev");
      const next = root.querySelector<HTMLButtonElement>(".carousel-next");
      if (!track || !dotsHost || !prev || !next) return;
      if (dotsHost.children.length > 0) return;

      const slides = Array.from(track.children) as HTMLElement[];
      if (slides.length === 0) return;

      // Build one dot per slide and wire activation.
      const dots: HTMLButtonElement[] = slides.map((_, i) => {
        const dot = document.createElement("button");
        dot.type = "button";
        dot.className = "carousel-dot";
        dot.setAttribute("role", "tab");
        dot.setAttribute("aria-label", `slide ${i + 1}`);
        dot.addEventListener("click", () => goTo(i));
        dotsHost.appendChild(dot);
        return dot;
      });

      let index = 0;
      const typewriterEnabled = root.dataset.typewriter === "true";
      const typewriter = typewriterEnabled ? new Typewriter() : null;

      function goTo(i: number) {
        index = (i + slides.length) % slides.length;
        const transform = `translateX(-${index * 100}%)`;
        // Sync every fold panel's carousel-track so when the fold scrolls
        // through before/after panels they land on the same slide as center.
        // Also flip `carousel-slide--active` so CSS can fade in/out alongside
        // the horizontal slide motion.
        document
          .querySelectorAll<HTMLElement>(".wrapper-3d .carousel-track")
          .forEach((t) => {
            t.style.transform = transform;
            Array.from(t.children).forEach((slide, si) => {
              (slide as HTMLElement).classList.toggle("carousel-slide--active", si === index);
            });
          });
        dots.forEach((dot, di) => {
          dot.setAttribute("aria-current", di === index ? "true" : "false");
        });
        // Typewrite the just-activated slide on every fold panel so when
        // the user scrolls into before/after they see the same animation.
        // Per-element tokens keep the three plays independent.
        if (typewriter) {
          document
            .querySelectorAll<HTMLElement>(".wrapper-3d .carousel-track")
            .forEach((t) => {
              const slide = t.children[index] as HTMLElement | undefined;
              if (slide) typewriter.play(slide, { totalMs: 1100 });
            });
        }
      }

      prev.addEventListener("click", () => goTo(index - 1));
      next.addEventListener("click", () => goTo(index + 1));

      // Keyboard nav — only when the carousel (or one of its controls) is focused.
      root.addEventListener("keydown", (event) => {
        const ke = event as KeyboardEvent;
        if (ke.key === "ArrowLeft") { ke.preventDefault(); goTo(index - 1); }
        else if (ke.key === "ArrowRight") { ke.preventDefault(); goTo(index + 1); }
      });

      goTo(0);
      root.dataset.carouselInit = "1";
    },
  });
</script>

<style>
  .carousel {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .carousel-viewport {
    overflow: hidden;
    width: 100%;
  }

  /* 0–0.4s: outgoing slides + fades out (motion visible during fade-out).
     0.4–0.8s: incoming fades in (already in position). Total 0.8s. */
  .carousel-track {
    display: flex;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .carousel-track > :global(*) {
    flex: 0 0 100%;
    min-width: 0;
    opacity: 0;
    transition: opacity 0.4s ease-in;
  }

  .carousel-track > :global(.carousel-slide--active) {
    opacity: 1;
    transition: opacity 0.4s ease-out 0.4s;
  }

  .carousel-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }

  .carousel-prev,
  .carousel-next {
    background: transparent;
    border: 1px solid color-mix(in oklab, var(--color-white-100) 20%, transparent);
    color: inherit;
    width: 32px;
    height: 32px;
    cursor: pointer;
    font: inherit;
    line-height: 1;
    transition: opacity 0.2s ease;
  }

  .carousel-prev:hover,
  .carousel-next:hover {
    opacity: 0.7;
  }

  .carousel-dots {
    display: flex;
    gap: 8px;
  }

  :global(.carousel-dot) {
    width: 8px;
    height: 8px;
    padding: 0;
    border: 0;
    border-radius: 50%;
    background: color-mix(in oklab, var(--color-white-100) 25%, transparent);
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  :global(.carousel-dot[aria-current="true"]) {
    background: var(--color-green-100);
    transform: scale(1.2);
  }
</style>
