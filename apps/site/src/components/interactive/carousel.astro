---
import IconArrowLeft from "../../assets/icons/icon-arrow-left.svg";
import IconArrowRight from "../../assets/icons/icon-arrow-right.svg";

interface Props {
  class?: string;
  ariaLabel?: string;
  typewriter?: boolean;
}

const {
  class: className,
  ariaLabel = "carousel",
  typewriter = false,
} = Astro.props;
---

<div
  class:list={["carousel", className]}
  aria-roledescription="carousel"
  aria-label={ariaLabel}
  data-typewriter={typewriter ? "true" : null}
>
  <div class="carousel-nav">
    <button type="button" class="carousel-prev" aria-label="previous slide">
      <IconArrowLeft width={14} height={14} />
    </button>
    <div class="carousel-dots" role="tablist"></div>
    <button type="button" class="carousel-next" aria-label="next slide">
      <IconArrowRight width={14} height={14} />
    </button>
  </div>
  <h4 class="carousel-title f-iosevka" aria-live="polite"></h4>
  <div class="carousel-viewport">
    <div class="carousel-track">
      <slot />
    </div>
  </div>
</div>

<script>
  import { watcher } from "../../core/watcher";
  import { Typewriter } from "../../core/effects/typewriter";
  import { Hacker } from "../../core/effects/hacker";

  const hacker = new Hacker();

  // Match every `.carousel` inside a `.fold` panel — that's the 3 fold
  // clones (before/center/after). Skip the source `#base-content` carousel
  // because cloneNode would copy its `data-carousel-init` flag to every
  // clone and lock them out. Click handlers / state attach only on
  // fold-center; before/after get dots only.
  document.addEventListener("astro:page-load", () => {
    watcher.add({
      selector: ".fold .carousel",
      onMatch: (root) => {
      if (root.dataset.carouselInit === "1") return;

      const track = root.querySelector<HTMLElement>(".carousel-track");
      const dotsHost = root.querySelector<HTMLElement>(".carousel-dots");
      const titleHost = root.querySelector<HTMLElement>(".carousel-title");
      const prev = root.querySelector<HTMLButtonElement>(".carousel-prev");
      const next = root.querySelector<HTMLButtonElement>(".carousel-next");
      if (!track || !dotsHost || !prev || !next) return;
      if (dotsHost.children.length > 0) return;

      const slides = Array.from(track.children) as HTMLElement[];
      if (slides.length === 0) return;

      const isCenter = !!root.closest(".fold-center");

      // Always render dots so before/after panels match center visually.
      // Click handlers attach only on the center carousel.
      const dots: HTMLButtonElement[] = slides.map((_, i) => {
        const dot = document.createElement("button");
        dot.type = "button";
        dot.className = "carousel-dot";
        dot.setAttribute("role", "tab");
        dot.setAttribute("aria-label", `slide ${i + 1}`);
        if (isCenter) dot.addEventListener("click", () => goTo(i));
        dotsHost.appendChild(dot);
        return dot;
      });

      if (!isCenter) {
        // Mark the clone's first dot as the active one so the visual
        // matches center on initial paint.
        dots[0]?.setAttribute("aria-current", "true");
        root.dataset.carouselInit = "1";
        return;
      }

      const titles = slides.map((s) => s.dataset.title ?? "");

      let index = 0;
      const typewriterEnabled = root.dataset.typewriter === "true";
      const typewriter = typewriterEnabled ? new Typewriter() : null;

      function goTo(i: number) {
        index = (i + slides.length) % slides.length;
        const transform = `translateX(-${index * 100}%)`;
        // Sync every fold panel's carousel-track so when the fold scrolls
        // through before/after panels they land on the same slide as center.
        // Also flip `carousel-slide--active` so CSS can fade in/out alongside
        // the horizontal slide motion.
        document
          .querySelectorAll<HTMLElement>(".wrapper-3d .carousel-track")
          .forEach((track) => {
            track.style.transform = transform;
            Array.from(track.children).forEach((slide, si) => {
              (slide as HTMLElement).classList.toggle("carousel-slide--active", si === index);
            });
          });

        dots.forEach((dot, idx) => {
          dot.setAttribute("aria-current", idx === index ? "true" : "false");
        });
        // Update the static title (lives outside the track, doesn't slide).
        // `-! ` prefix mirrors the inline editor-title convention.
        // Trigger the hacker decode every time the carousel navigates —
        // no hover binding. 20 × 20ms = 400ms, matches slide duration.
        if (titleHost) {
          titleHost.textContent = `-! ${titles[index]}`;
          hacker.split(titleHost);
          hacker.play(titleHost, { iterations: 20, charDelayMs: 20 });
        }
        // Typewrite the just-activated slide on every fold panel so when
        // the user scrolls into before/after they see the same animation.
        // Per-element tokens keep the three plays independent.
        if (typewriter) {
          document
            .querySelectorAll<HTMLElement>(".wrapper-3d .carousel-track")
            .forEach((track) => {
              const slide = track.children[index] as HTMLElement | undefined;
              if (slide) typewriter.play(slide, { totalMs: 1100 });
            });
        }
      }

      prev.addEventListener("click", () => goTo(index - 1));
      next.addEventListener("click", () => goTo(index + 1));

      // Keyboard nav — only when the carousel (or one of its controls) is focused.
      root.addEventListener("keydown", (event: KeyboardEvent) => {
        if (event.key === "ArrowLeft") {
          event.preventDefault();
          goTo(index - 1);
        } else if (event.key === "ArrowRight") {
          event.preventDefault();
          goTo(index + 1);
        }
      });

      goTo(0);

      root.dataset.carouselInit = "1";
    },
    });
  });
</script>

<style>
  .carousel {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .carousel-viewport {
    width: 100%;
    overflow: hidden;
  }

  /* 0–0.4s: outgoing slides + fades out (motion visible during fade-out).
     0.4–0.8s: incoming fades in (already in position). Total 0.8s. */
  .carousel-track {
    display: flex;
    transition: transform 400ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .carousel-track > :global(*) {
    flex: 0 0 100%;
    min-width: 0;
    opacity: 0;
    transition: opacity 400ms ease-in;
  }

  .carousel-track > :global(.carousel-slide--active) {
    opacity: 1;
    transition: opacity 400ms ease-out 400ms;
  }

  .carousel-nav {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 16px;
    border: 1px solid
      color-mix(in oklab, var(--color-white-100) 20%, transparent);
  }

  /* Mirrors `.editor-title` from editor.astro exactly so the static
     out-of-slide title is visually indistinguishable from the inline one. */
  .carousel-title {
    margin: 0;
    min-height: 1.4em;
    opacity: 0.65;
    color: var(--color-grasy-100);
    font-weight: 400;
  }


  .carousel-dots {
    flex: 1 1 auto;
    justify-content: center;
  }

  .carousel-prev,
  .carousel-next {
    padding: 0;
    width: 32px;
    height: 32px;
    cursor: pointer;
    border: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    color: inherit;
    transition: opacity 350ms ease;
  }

  .carousel-prev {
    border-right: 1px solid
      color-mix(in oklab, var(--color-white-100) 20%, transparent);
  }

  .carousel-next {
    border-left: 1px solid
      color-mix(in oklab, var(--color-white-100) 20%, transparent);
  }

  .carousel-prev:hover,
  .carousel-next:hover {
    opacity: 0.7;
  }

  .carousel-dots {
    display: flex;
    gap: 8px;
  }

  :global(.carousel-dot) {
    width: 18px;
    height: 8px;
    padding: 0;
    border: 0;
    background: color-mix(in oklab, var(--color-white-100) 25%, transparent);
    cursor: pointer;
    transition: background 350ms ease, transform 350ms ease-in-out;
  }

  :global(.carousel-dot[aria-current="true"]) {
    background: var(--color-green-100);
    transform: scale(1.2);
  }
</style>
