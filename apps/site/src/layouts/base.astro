---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { getLocale } from "../paraglide/runtime.js";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const locale = getLocale();
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <!-- open graph / facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
    <!-- ai geo -->
    <meta name="description" content="zo: Turn thoughts into type-safe software and UI instantly. High-performance, data-oriented language by Compilords." />
    <link rel="alternate" type="text/plain" title="LLM Documentation" href="https://zo.compilords.house/docs/llms-full.txt" />
    <!-- ai specific JSON-LD -->
		<script type="application/ld+json">
		  {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "zo",
        "alternateName": "zo Programming Language",
        "description": "A high-performance programming language designed to turn thoughts into type-safe software and UI instantly. Optimized for speed, simplicity, and data-oriented design.",
        "applicationCategory": "DeveloperApplication",
        "operatingSystem": "Linux, macOS, Windows, Web",
        "downloadUrl": "https://zo.compilords.house/install.sh",
        "featureList": [
          "Execution-based compilation (10M LoC/s)",
          "zsx (zo syntax extension) for unified UI",
          "Hindley-Milner type inference",
          "Structured concurrency",
          "Zero-config package management with fret"
        ],
        "author": {
          "@type": "Organization",
          "name": "Compilords",
          "url": "https://compilords.house"
        },
        "offers": {
          "@type": "Offer",
          "price": "0.00",
          "priceCurrency": "USD"
        },
        "softwareHelp": {
          "@type": "CreativeWork",
          "url": "https://zo.compilords.house/initiation"
        },
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": "https://zo.compilords.house"
        }
		  }
		</script>
    <!-- ai specific JSON-LD -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ComputerLanguage",
        "name": "zo",
        "alternateName": "zo-lang",
        "description": "A feature-rich ecosystem focused on high-performance, simplicity and data-oriented programming.",
        "url": "https://zo.compilords.house",
        "identifier": "https://github.com/invisageable/zo"
      }
    </script>
    <!-- ai geo: WebSite + SearchAction (signals "real site", enables Google's site-search rich result). -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "zo",
        "alternateName": "zo Programming Language",
        "url": "https://zo.compilords.house",
        "publisher": {
          "@type": "Organization",
          "name": "Compilords",
          "url": "https://compilords.house"
        },
        "potentialAction": {
          "@type": "SearchAction",
          "target": "https://zo.compilords.house/initiation?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      }
    </script>
    <ClientRouter />
  </head>
  <body>
    <slot />
  </body>
</html>

<script>
  import { renderer } from "../core/renderer";
  import { watcher } from "../core/watcher";
  import { observer } from "../core/observer";

  // View-transitions lifecycle: before the DOM swap, tear down every
  // singleton's per-page state. References to soon-to-be-replaced
  // elements would otherwise keep firing rAF ticks, MutationObserver
  // callbacks, and IntersectionObserver entries against ghost nodes.
  // Components themselves re-attach on `astro:page-load`.
  document.addEventListener("astro:before-swap", () => {
    renderer.reset();
    watcher.disconnect();
    observer.disconnect();
  });
</script>
