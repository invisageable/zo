---
import Title from "../../components/atoms/title.astro";
import Base from "../../layouts/base.astro";
import Paragraph from "../../components/atoms/paragraph.astro";
import NavBar, { type Item } from "../../components/navigation/navbar.astro";
import Header from "../../components/structure/header.astro";
import Screen from "../../components/structure/screen.astro";
import Reachout from "../../components/structure/reachout.astro";

import {
  loadNews,
  getNewsNavItems,
  pad2,
  formatEpisodeId,
  formatDate,
} from "../../core/news";
import { getLocale } from "../../paraglide/runtime.js";
import * as m from "../../paraglide/messages";

const locale = getLocale();
const news = (await loadNews(locale)).slice().reverse();
const items: Item[] = await getNewsNavItems(locale);
---

<Base title="zo — News.">
  <NavBar items={items} />
  <Header class="header--fixed header--active blur" id="top-bar" />
  <Screen>
    <Title class="news-title" as="h1">
      News
      <span class="news-count" data-total={news.length} />
    </Title>
    <Paragraph content={m.news_description()} />
    <section>
      <ul class="news-list">
        {
          news.map(({ entry, meta }) => <li class="news-item" data-season={pad2(meta.season)}>
            <a href={`/news/${meta.slug}`}>
              <span class="news-id">{formatEpisodeId(meta.season, meta.episode)}</span>
              <span class="news-date">{formatDate(meta.date)}</span>
              <span class="news-title">{meta.subtitle ?? entry.id.split("/").pop()}</span>
            </a>
          </li>)
        }
      </ul>
    </section>
    <Reachout />
  </Screen>
</Base>

<script>
  import { renderer } from "../../core/renderer";
  import { observer } from "../../core/observer";
  import { watcher } from "../../core/watcher";
  import { Counter } from "../../core/effects/counter";

  function countFor(season: string | null): number {
    const root = document.querySelector(".fold-center");
    if (!root) return 0;
    const selector = season === null
      ? ".news-item"
      : `.news-item[data-season="${season}"]`;
    return root.querySelectorAll(selector).length;
  }

  document.addEventListener("astro:page-load", () => {
    const counters: Counter[] = [];

    watcher.add({
      selector: '.news-count',
      onMatch: (elmt) => {
        const total = Number(elmt.dataset.total ?? 0);
        const counter = new Counter(elmt, total, 350);
        counters.push(counter);
        renderer.add(counter);
        observer.add(counter);
      },
    });

    function applyFilter(hashOverride?: string) {
      const raw = (hashOverride ?? location.hash).replace(/^#?\/?(news#)?/, "");
      const season = /^s\d+$/.test(raw) ? raw.slice(1) : null;

      document
        .querySelectorAll<HTMLElement>(".news-item")
        .forEach((item) => {
          const matches = season === null || item.dataset.season === season;
          item.classList.toggle("news-item--hidden", !matches);
        });

      document
        .querySelectorAll<HTMLAnchorElement>(".table-of-content-item")
        .forEach((link) => {
          const target = link.getAttribute("href")?.slice(1) ?? "";
          const isActive =
            (season === null && target === "all") ||
            (season !== null && target === `s${season}`);
          link.classList.toggle("table-of-content-item--active", isActive);
        });

      const target = countFor(season);
      counters.forEach((counter) => counter.setTarget(target));
    }

    window.addEventListener("hashchange", () => applyFilter());
    document
      .querySelectorAll<HTMLAnchorElement>(".table-of-content-item")
      .forEach((link) => {
        link.addEventListener("click", () => {
          applyFilter(link.getAttribute("href") ?? "");
        });
      });
    applyFilter();

    renderer.render();
  });
</script>

<style is:global>
  .news-item--hidden {
    display: none;
  }
</style>

<style>
  .news-count {
    font-size: 4rem;
    &::before { content: "("; }
    &::after  { content: ")"; }
  }

  .news-list {
    margin: 24px 0 0;
    padding: 0;
    list-style: none;
  }

  .news-item a {
    display: grid;
    grid-template-columns: 80px 100px 1fr;
    gap: 16px;
    padding: 8px 0;
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--color-white-100) 10%, transparent);
  }

  .news-item a:hover {
    background: color-mix(in oklab, var(--color-white-100) 5%, transparent);
  }

  .news-id {
    font-family: var(--font-iosevka);
    color: var(--color-green-100);
  }

  .news-date {
    font-family: var(--font-iosevka);
    opacity: 0.6;
  }
</style>
