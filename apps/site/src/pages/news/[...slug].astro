---
import { render } from "astro:content";
import Base from "../../layouts/base.astro";
import Header from "../../components/structure/header.astro";
import Screen from "../../components/structure/screen.astro";
import NavBar, { type Item } from "../../components/navigation/navbar.astro";
import NewsNav from "../../components/navigation/news-nav.astro";
import {
  loadNews,
  getNewsNavItems,
  formatEpisodeId,
  formatDate,
} from "../../core/news";
import { getLocale } from "../../paraglide/runtime.js";

const locale = getLocale();
const slug = Astro.params.slug;
const sorted = await loadNews(locale);
const index = sorted.findIndex((n) => n.meta.slug === slug);

if (index < 0) {
  return Astro.redirect("/news");
}

const { entry, meta } = sorted[index];
const prevEntry = sorted[index - 1] ?? null;
const nextEntry = sorted[index + 1] ?? null;
const prev = prevEntry
  ? { slug: prevEntry.meta.slug, subtitle: prevEntry.meta.subtitle }
  : null;
const next = nextEntry
  ? { slug: nextEntry.meta.slug, subtitle: nextEntry.meta.subtitle }
  : null;

const { Content } = await render(entry);

const items: Item[] = await getNewsNavItems(locale, "/news");
const episodeId = formatEpisodeId(meta.season, meta.episode);

const articleHeadline = meta.subtitle ?? `zo — ${episodeId}`;
const articleUrl = new URL(Astro.url.pathname, Astro.site).toString();
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: articleHeadline,
  datePublished: meta.date.toISOString(),
  url: articleUrl,
  author: {
    "@type": "Organization",
    name: "Compilords",
    url: "https://compilords.house",
  },
  publisher: {
    "@type": "Organization",
    name: "Compilords",
    url: "https://compilords.house",
  },
  isPartOf: {
    "@type": "WebSite",
    name: "zo",
    url: "https://zo.compilords.house",
  },
  mainEntityOfPage: { "@type": "WebPage", "@id": articleUrl },
};
---

<Base title={`zo — ${episodeId}.`} description="">
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <NavBar items={items} />
  <Header class="header--fixed header--active blur" id="top-bar" />
  <Screen>
    <article class="news">
      <header class="news-meta">
        <span class="news-id">{episodeId}</span>
        <span class="news-date">{formatDate(meta.date)}</span>
      </header>
      <NewsNav prev={prev} next={next} />
      <Content />
      <NewsNav prev={prev} next={next} />
    </article>
  </Screen>
</Base>

<style>
  .news {
    max-width: 720px;
    margin: 24px auto 0;
  }

  .news-meta {
    display: flex;
    gap: 16px;
    font-family: var(--font-iosevka);
    color: var(--color-green-100);
    margin-bottom: 16px;
  }

  .news-date {
    opacity: 0.6;
  }
</style>

<style is:global>
  .news img {
    width: 100%;
    height: auto;
  }

  .news pre {
    padding: 8px;
    overflow-x: auto;
  }
</style>
