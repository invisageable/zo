---
import * as m from '../paraglide/messages';
import Base from '../layouts/base.astro';
import Screen from '../components/structure/screen.astro';
import NavBar, { type Item } from '../components/navigation/navbar.astro';
import Oss from '../components/structure/oss.astro';
import Hero from '../components/structure/hero.astro';
import Prologue from '../components/structure/prologue.astro';
import Features from '../components/structure/features.astro';
import Purpose from '../components/structure/purpose.astro';
import Benchmarks from '../components/structure/benchmarks.astro';
import Showcase from '../components/structure/showcase.astro';
import Manifesto from '../components/structure/manifesto.astro';
import Tools from '../components/structure/tools.astro';
import Reachout from '../components/structure/reachout.astro';
import Header from '../components/structure/header.astro';
import Sponsors from '../components/structure/sponsors.astro';
import Community from '../components/structure/community.astro';
import Foundations from '../components/structure/foundations.astro';

const title = "zo Programming Language.";
const description = "Turn your thoughts into type-safe software and Ui instantly.";

const items = [
	{ href: "#prologue", label: m.nav_prologue() },
	{ href: "#features", label: m.nav_features() },
	{ href: "#purpose", label: m.nav_purpose() },
	{ href: "#benchmarks", label: m.nav_benchmarks() },
	{ href: "#showcase", label: "Showcase" },
	{ href: "#manifesto", label: m.nav_manifesto() },
	{ href: "#tools", label: m.nav_tools() },
	// { href: "#talks", label: "Talks" },
	{ href: "#oss", label: m.nav_oss() },
	{ href: "#foundations", label: m.nav_foundations() },
	{ href: "#community", label: m.nav_community() },
	{ href: "#sponsors", label: m.nav_sponsors() },
	{ href: "#reachout", label: m.nav_reachout() },
] as Item[];
---

<Base title={title} description={description}>
	<NavBar items={items} />
	<Header class="header--fixed blur" id="top-bar" />
	<Screen>
    <Hero />
		<Prologue />
		<Features />
		<Purpose />
		<Benchmarks />
		<Showcase />
		<Manifesto />
		<Tools />
		<Oss />
		<Foundations />
		<Community />
		<Sponsors />
		<Reachout />
	</Screen>
</Base>

<script>
	async function preload() {
		// import zo wasm compiler here.
	}

	async function run() {
		await preload();
	}

	window.addEventListener("astro:page-load", async () => await run(), false);
</script>
