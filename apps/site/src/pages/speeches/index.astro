---
import {
  loadSpeeches,
  getSpeechNavItems,
  pad2,
  formatEpisodeId,
  formatDate,
} from "../../core/speech";

import Title from "../../components/atoms/title.astro";
import Base from "../../layouts/base.astro";
import Paragraph from "../../components/atoms/paragraph.astro";
import NavBar, { type Item } from "../../components/navigation/navbar.astro";
import Header from "../../components/structure/header.astro";
import Screen from "../../components/structure/screen.astro";
import Reachout from "../../components/structure/reachout.astro";
import { getLocale } from "../../paraglide/runtime.js";
import * as m from "../../paraglide/messages";

const locale = getLocale();
const speeches = (await loadSpeeches(locale)).slice().reverse();
const items: Item[] = await getSpeechNavItems(locale);
---

<Base title="zo — Speeches.">
  <NavBar items={items} />
  <Header class="header--fixed header--active blur" id="top-bar" />
  <Screen>
    <Title class="speeches-title" as="h1">
      Speeches
      <span class="speeches-count" data-total={speeches.length} />
    </Title>
    <Paragraph content={m.speeches_description()} />
    <section>
      <ul class="speeches-list">
        {
          speeches.map(({ entry, meta }) => <li
            class="speeches-item"
            data-season={pad2(meta.season)}
          >
            <a href={`/speeches/${meta.slug}`}>
              <span class="speeches-id">{formatEpisodeId(meta.season, meta.episode)}</span>
              <span class="speeches-date">{formatDate(meta.date)}</span>
              <span class="speeches-title">{meta.subtitle ?? entry.id.split("/").pop()}</span>
            </a>
          </li>)
        }
      </ul>
    </section>
    <Reachout />
  </Screen>
</Base>

<script>
  import { renderer } from "../../core/renderer";
  import { observer } from "../../core/observer";
  import { watcher } from "../../core/watcher";
  import { Counter } from "../../core/effects/counter";

  function countFor(season: string | null): number {
    // Count from `.fold-center` — the single visible copy. The other fold
    // panels and the hidden source would multiply the total otherwise.
    const root = document.querySelector(".fold-center");
    if (!root) return 0;

    const selector = season === null
      ? ".speeches-item"
      : `.speeches-item[data-season="${season}"]`;

    return root.querySelectorAll(selector).length;
  }

  // Re-binds on every page load. Fresh `counters` array per page so the
  // hashchange handler doesn't drive ghost Counters from the prior page.
  document.addEventListener("astro:page-load", () => {
    // Each fold-cloned `.speeches-count` gets its own Counter — intro
    // animation on viewport enter, then `setTarget` on filter change.
    const counters: Counter[] = [];

    watcher.add({
      selector: '.speeches-count',
      onMatch: (elmt) => {
        const total = Number(elmt.dataset.total ?? 0);
        const counter = new Counter(elmt, total, 350);
        counters.push(counter);
        renderer.add(counter);
        observer.add(counter);
      },
    });

    function applyFilter(hashOverride?: string) {
      // Click handler passes the link's `href` directly because
      // location.hash hasn't settled yet when ClientRouter intercepts.
      const raw = (hashOverride ?? location.hash).replace(/^#?\/?(speeches#)?/, "");
      const season = /^s\d+$/.test(raw) ? raw.slice(1) : null;

      document
        .querySelectorAll<HTMLElement>(".speeches-item")
        .forEach((item) => {
          const matches = season === null || item.dataset.season === season;
          item.classList.toggle("speeches-item--hidden", !matches);
        });

      document
        .querySelectorAll<HTMLAnchorElement>(".table-of-content-item")
        .forEach((link) => {
          const target = link.getAttribute("href")?.slice(1) ?? "";
          const isActive =
            (season === null && target === "all") ||
            (season !== null && target === `s${season}`);
          link.classList.toggle("table-of-content-item--active", isActive);
        });

      const target = countFor(season);
      counters.forEach((counter) => counter.setTarget(target));
    }

    window.addEventListener("hashchange", () => applyFilter());
    // ClientRouter intercepts <a href="#sXX"> clicks and may update the URL
    // via history.pushState, which doesn't fire `hashchange` and doesn't
    // settle location.hash before our handler runs. Read the link's `href`
    // directly instead of waiting on the URL to update.
    document
      .querySelectorAll<HTMLAnchorElement>(".table-of-content-item")
      .forEach((link) => {
        link.addEventListener("click", () => {
          applyFilter(link.getAttribute("href") ?? "");
        });
      });
    applyFilter();

    renderer.render();
  });
</script>

<style is:global>
  .speeches-item--hidden {
    display: none;
  }
</style>

<style>
  .speeches-count {
    font-size: 4rem;
    &::before { content: "("; }
    &::after  { content: ")"; }
  }

  .speeches-list {
    margin: 24px 0 0;
    padding: 0;
    list-style: none;
  }

  .speeches-item a {
    display: grid;
    grid-template-columns: 80px 100px 1fr;
    gap: 16px;
    padding: 8px 0;
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--color-white-100) 10%, transparent);
  }

  .speeches-item a:hover {
    background: color-mix(in oklab, var(--color-white-100) 5%, transparent);
  }

  .speeches-id {
    font-family: var(--font-iosevka);
    color: var(--color-green-100);
  }

  .speeches-date {
    font-family: var(--font-iosevka);
    opacity: 0.6;
  }
</style>
