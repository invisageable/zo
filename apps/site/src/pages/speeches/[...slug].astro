---
import { render } from "astro:content";
import Base from "../../layouts/base.astro";
import Header from "../../components/structure/header.astro";
import Screen from "../../components/structure/screen.astro";
import NavBar, { type Item } from "../../components/navigation/navbar.astro";
import SpeechNav from "../../components/navigation/speech-nav.astro";
import {
  loadSpeeches,
  getSpeechNavItems,
  formatEpisodeId,
  formatDate,
} from "../../core/speech";

export async function getStaticPaths() {
  const sorted = await loadSpeeches();

  return sorted.map(({ entry, meta }, i) => {
    const prev = sorted[i - 1] ?? null;
    const next = sorted[i + 1] ?? null;
    return {
      params: { slug: meta.slug },
      props: {
        entry,
        meta,
        prev: prev ? { slug: prev.meta.slug, subtitle: prev.meta.subtitle } : null,
        next: next ? { slug: next.meta.slug, subtitle: next.meta.subtitle } : null,
      },
    };
  });
}

const { entry, meta, prev, next } = Astro.props;
const { Content } = await render(entry);

const items: Item[] = await getSpeechNavItems("/speeches");
const episodeId = formatEpisodeId(meta.season, meta.episode);
---

<Base title={`zo — ${episodeId}.`}>
  <NavBar items={items} />
  <Header class="header--fixed header--active blur" id="top-bar" />
  <Screen>
    <article class="speech">
      <header class="speech-meta">
        <span class="speech-id">{episodeId}</span>
        <span class="speech-date">{formatDate(meta.date)}</span>
      </header>
      <SpeechNav prev={prev} next={next} />
      <Content />
      <SpeechNav prev={prev} next={next} />
    </article>
  </Screen>
</Base>

<style>
  .speech {
    max-width: 720px;
    margin: 24px auto 0;
  }

  .speech-meta {
    display: flex;
    gap: 16px;
    font-family: var(--font-iosevka);
    color: var(--color-green-100);
    margin-bottom: 16px;
  }

  .speech-date {
    opacity: 0.6;
  }
</style>

<style is:global>
  .speech img {
    width: 100%;
    height: auto;
  }

  /* Black background on every code block — overrides Shiki's inline
     `background-color` so its output matches our zo-block. */
  .speech pre {
    background: #000 !important;
    padding: 8px;
    overflow-x: auto;
  }

  /* zo highlighter palette — duplicated from `components/interactive/editor.astro`
     because that component's styles are scoped and don't reach Markdown HTML. */
  .speech .zo-block {
    --color-yellow-100: #e6db74;
    --color-orange-100: #fd971f;
    --color-red-100: #f92672;
    --color-purple-100: #ae81ff;
    --color-blue-100: #66d9ef;
    --color-cyan-100: #a1efe4;
    --color-magenta-100: #fd5ff0;
    --color-gray-100: #43443b;
    --color-gray-200: #75715e;
  }

  .speech .zo-block .keyword     { color: var(--color-blue-100); }
  .speech .zo-block .ident       { color: var(--color-green-100); }
  .speech .zo-block .group       { color: var(--color-gray-200); }
  .speech .zo-block .punctuation { color: var(--color-red-100); }
  .speech .zo-block .number      { color: var(--color-purple-100); }
  .speech .zo-block .comment     { color: var(--color-gray-100); }
  .speech .zo-block .string      { color: var(--color-yellow-100); }
  .speech .zo-block .type        { color: var(--color-cyan-100); }
  .speech .zo-block .attribute   { color: var(--color-orange-100); }
  .speech .zo-block .event       { color: var(--color-magenta-100); }
  .speech .zo-block .boolean     { color: var(--color-orange-100); }
</style>
