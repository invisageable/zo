---
import {
  loadSpeeches,
  getSpeechNavItems,
  formatEpisodeId,
  formatDate,
} from "../../core/speech";

import Base from "../../layouts/base.astro";
import Header from "../../components/structure/header.astro";
import Screen from "../../components/structure/screen.astro";
import NavBar, { type Item } from "../../components/navigation/navbar.astro";
import SpeechNav from "../../components/navigation/speech-nav.astro";

import { render } from "astro:content";
import { getLocale } from "../../paraglide/runtime.js";

// SSR slug lookup: locale comes from the request, the speech is found
// inside the per-locale list (with EN fallback baked into loadSpeeches).
const locale = getLocale();
const slug = Astro.params.slug;
const sorted = await loadSpeeches(locale);
const index = sorted.findIndex((s) => s.meta.slug === slug);

if (index < 0) {
  return Astro.redirect("/speeches");
}

const { entry, meta } = sorted[index];
const prevEntry = sorted[index - 1] ?? null;
const nextEntry = sorted[index + 1] ?? null;
const prev = prevEntry
  ? { slug: prevEntry.meta.slug, subtitle: prevEntry.meta.subtitle }
  : null;
const next = nextEntry
  ? { slug: nextEntry.meta.slug, subtitle: nextEntry.meta.subtitle }
  : null;

const { Content } = await render(entry);

const items: Item[] = await getSpeechNavItems(locale, "/speeches");
const episodeId = formatEpisodeId(meta.season, meta.episode);
---

<Base title={`zo — ${episodeId}.`}>
  <NavBar items={items} />
  <Header class="header--fixed header--active blur" id="top-bar" />
  <Screen>
    <article class="speech">
      <header class="speech-meta">
        <span class="speech-id">{episodeId}</span>
        <span class="speech-date">{formatDate(meta.date)}</span>
      </header>
      <SpeechNav prev={prev} next={next} />
      <Content />
      <SpeechNav prev={prev} next={next} />
    </article>
  </Screen>
</Base>

<style>
  .speech {
    max-width: 720px;
    margin: 24px auto 0;
  }

  .speech-meta {
    display: flex;
    gap: 16px;
    font-family: var(--font-iosevka);
    color: var(--color-green-100);
    margin-bottom: 16px;
  }

  .speech-date {
    opacity: 0.6;
  }
</style>

<style is:global>
  .speech img {
    width: 100%;
    height: auto;
  }

  /* Black background on every code block — overrides Shiki's inline
     `background-color` so its output matches our zo-block. */
  .speech pre {
    background: #000 !important;
    padding: 8px;
    overflow-x: auto;
  }
</style>
